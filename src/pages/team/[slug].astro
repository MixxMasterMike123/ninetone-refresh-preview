---
import Base from "../../layouts/Base.astro";
import { getTeam } from "../../lib/ninetone";
import { renderBio, isAiSpeculative } from "../../lib/markdown";
import { url } from "../../lib/url";

export async function getStaticPaths() {
  const team = await getTeam();
  return team
    .filter((m) => m.SLUG)
    .map((m) => ({
      params: { slug: String(m.SLUG) },
      props: { member: m },
    }));
}

const { member } = Astro.props as { member: Record<string, unknown> };

const name = String(member.userNameCalc ?? "");
const title = String(member.title ?? "");
const titleDescription = String(member.titleDescription ?? "");
const rawDescription = String(member.DescriptionString ?? member.Description ?? "");
const aiBio = isAiSpeculative(rawDescription);
const descriptionHtml = aiBio ? "" : renderBio(rawDescription);
const photo = member.userPhoto
  ? String(member.userPhoto)
  : member.userPhotoSmall
  ? String(member.userPhotoSmall)
  : undefined;
const email = String(member.userEmail ?? "");
const phone = String(member.Phone ?? "");
---

<Base title={name}>
  <section class="bg-ninetone-paper">
    <div class="mx-auto max-w-7xl px-6 pb-12 pt-12 md:pt-16">
      <p class="mb-8">
        <a href={url("/team")} class="kicker text-ninetone-ink/55 hover:text-ninetone-ink">← Team</a>
      </p>

      <div class="grid gap-10 md:grid-cols-12 md:gap-16">
        <aside class="md:col-span-4 lg:col-span-4">
          <div class="md:sticky md:top-24">
            {/* FM team photos are 200×200 — cap container so we never upscale.
                Width 240px ≈ 1.2× source, beyond which pixelation becomes visible. */}
            <div class="fm-img-frame relative aspect-square w-60 max-w-full overflow-hidden bg-ninetone-paper-warm">
              {photo && (
                <img
                  src={photo}
                  alt={name}
                  width="240"
                  height="240"
                  class="fm-img h-full w-full object-cover grayscale transition-all duration-700 ease-out hover:grayscale-0"
                  onload="this.classList.add('is-loaded'); this.closest('.fm-img-frame')?.classList.add('is-ready')"
                />
              )}
              <span class="absolute left-0 top-0 h-1 w-12 bg-ninetone-ink" aria-hidden></span>
            </div>
            <div class="mt-6 hidden w-60 max-w-full flex-col gap-3 md:flex">
              {email && (
                <a
                  href={`mailto:${email}`}
                  class="inline-flex items-center justify-center gap-2 bg-ninetone-ink px-4 py-3 text-sm font-semibold text-ninetone-paper transition-colors hover:bg-ninetone-ink-soft"
                >
                  Email <span aria-hidden>→</span>
                </a>
              )}
              {phone && (
                <a
                  href={`tel:${phone.replace(/\s/g, "")}`}
                  class="inline-flex items-center justify-center gap-2 border border-ninetone-ink/20 px-4 py-3 text-sm font-semibold text-ninetone-ink transition-colors hover:border-ninetone-ink"
                >
                  {phone}
                </a>
              )}
            </div>
          </div>
        </aside>

        <div class="md:col-span-8 lg:col-span-8">
          <span class="kicker text-ninetone-ink/55">Ninetone — Team</span>
          <h1 class="mt-4 font-display text-[clamp(3rem,8vw,7rem)] leading-[0.9] tracking-[-0.045em]">{name}</h1>

          {title && (
            <p class="mt-6 max-w-xl font-display text-2xl italic leading-snug tracking-tight text-ninetone-ink/75 md:text-3xl">
              {title}
            </p>
          )}

          {titleDescription && titleDescription !== title && (
            <p class="mt-4 font-mono text-[0.75rem] uppercase tracking-[0.12em] text-ninetone-ink/55">{titleDescription}</p>
          )}

          <!-- Mobile contact buttons -->
          {(email || phone) && (
            <div class="mt-8 flex flex-col gap-3 md:hidden">
              {email && (
                <a
                  href={`mailto:${email}`}
                  class="inline-flex items-center justify-center gap-2 bg-ninetone-ink px-4 py-3 text-sm font-semibold text-ninetone-paper"
                >
                  Email <span aria-hidden>→</span>
                </a>
              )}
              {phone && (
                <a
                  href={`tel:${phone.replace(/\s/g, "")}`}
                  class="inline-flex items-center justify-center gap-2 border border-ninetone-ink/20 px-4 py-3 text-sm font-semibold text-ninetone-ink"
                >
                  {phone}
                </a>
              )}
            </div>
          )}

          {descriptionHtml ? (
            <div class="mt-12 prose lede max-w-none" set:html={descriptionHtml}></div>
          ) : (
            <div class="mt-12 border-t border-ninetone-rule pt-8 text-base text-ninetone-ink/65">
              {email ? (
                <>For more about {name}, get in touch at <a href={`mailto:${email}`} class="text-ninetone-ink underline-offset-4 hover:underline">{email}</a>.</>
              ) : (
                <>More about {name} coming soon.</>
              )}
            </div>
          )}
        </div>
      </div>
    </div>
  </section>
</Base>
