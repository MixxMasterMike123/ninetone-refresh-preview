---
import Base from "../../layouts/Base.astro";
import ContactForm from "../../components/ContactForm.astro";
---

<Base title="Get in touch" theme="management">
  <ContactForm
    theme="management"
    kicker="Management — Enquiry"
    heading="We succeed together."
    tagline="Building a serious career? Let's talk."
    blurb="Tell us what you're working on. Send the channels you're proud of and where you'd like to be in eighteen months."
    metrics={[
      { value: "38", label: "Active clients" },
      { value: "12+", label: "Brand partners / mo" },
      { value: "4M", label: "Combined reach" },
      { value: "1", label: "Address — Sundsvall" },
    ]}
    formTitle="Tell us about you."
    formBlurb="Drop links to the social channels and projects you want us to see."
    submitLabel="Send enquiry"
    fields={[
      { type: "text", name: "name", label: "Name", placeholder: "Your name", required: true },
      { type: "email", name: "email", label: "Email", placeholder: "you@email.com", required: true },
      { type: "textarea", name: "links", label: "Channels / links", placeholder: "TikTok, Instagram, YouTube, portfolio… one per line", rows: 4, required: true },
      { type: "textarea", name: "about", label: "About you", placeholder: "A few lines on what you're building and where you want it to go", rows: 4 },
    ]}
  />
</Base>
