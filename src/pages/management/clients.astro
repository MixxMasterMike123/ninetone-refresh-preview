---
import Base from "../../layouts/Base.astro";
import ArtistCard from "../../components/ArtistCard.astro";
import SectionIntro from "../../components/SectionIntro.astro";
import RosterFilters from "../../components/RosterFilters.astro";
import RosterIndex from "../../components/RosterIndex.astro";
import { getClients, getWebPostSection } from "../../lib/ninetone";

let clients: Awaited<ReturnType<typeof getClients>> = [];
let fetchError: string | null = null;
try {
  clients = await getClients();
} catch (e) {
  fetchError = (e as Error).message;
}
const introBody = String((clients[0] as Record<string, unknown> | undefined)?.readMoreClients ?? "");
const webPosts = await getWebPostSection("Ninetone Management").catch(() => null);

function tagsOf(c: Record<string, unknown>): string[] {
  const raw = (c.tags ?? c.genre ?? "") as string;
  return String(raw).split(/\r|\n|,/).map((s) => s.trim()).filter(Boolean);
}

const tagCounts = new Map<string, number>();
for (const c of clients) {
  for (const t of tagsOf(c)) {
    tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
  }
}
const sortedTags = Array.from(tagCounts.entries())
  .sort((a, b) => b[1] - a[1])
  .slice(0, 12)
  .map(([t]) => t);
---

<Base title="Clients" theme="management">
  <SectionIntro
    title="Clients"
    tagline={webPosts?.title}
    readMore={introBody}
    theme="management"
    logo="/images/managementLogo.png"
    logoAlt="Ninetone Management"
  />

  <section class="bg-ninetone-paper pb-20">
    <div class="mx-auto max-w-7xl px-6">
      {fetchError && (
        <p class="border-l-2 border-ninetone-navy bg-ninetone-paper-warm p-4 text-sm text-ninetone-ink/80">
          Couldn't load clients yet — set FM_USER / FM_PASS in .env to enable.
        </p>
      )}

      <RosterFilters
        tags={sortedTags}
        theme="management"
        total={clients.length}
        showLayoutSwitch
      />

      <div
        data-roster-grid
        class="grid grid-cols-2 gap-x-6 gap-y-12 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5"
      >
        {clients.map((c) => {
          const name = String(c["Head Artist"] ?? "");
          const tags = tagsOf(c);
          return (
            <div
              data-roster-item
              data-name={name}
              data-letter={(name[0] ?? "").toLowerCase()}
              data-tags={tags.join("|")}
            >
              <ArtistCard
                theme="management"
                name={name}
                slug={String(c.SLUG ?? "")}
                blurb={String(c.clientPresentationString ?? c.artistPresentationShort ?? "")}
                image={c.artistPicture_small ? String(c.artistPicture_small) : undefined}
                tags={tags}
                socials={{
                  instagram: c.url_instagram ? String(c.url_instagram) : undefined,
                  tiktok: c.url_tiktok_artist ? String(c.url_tiktok_artist) : undefined,
                  twitter: c.url_twitter ? String(c.url_twitter) : undefined,
                  facebook: c.url_facebook ? String(c.url_facebook) : undefined,
                  youtube: c.url_youtube_link ? String(c.url_youtube_link) : undefined,
                }}
              />
            </div>
          );
        })}
      </div>

      <RosterIndex artists={clients} hrefBase="/management/clients" />
    </div>
  </section>
</Base>
