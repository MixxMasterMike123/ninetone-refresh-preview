---
import Base from "../../../layouts/Base.astro";
import SocialRow from "../../../components/SocialRow.astro";
import MerchCard from "../../../components/MerchCard.astro";
import { getClients, getNewsForArtist } from "../../../lib/ninetone";
import { getProducts } from "../../../lib/shopify";
import NewsCard from "../../../components/NewsCard.astro";
import { renderBio } from "../../../lib/markdown";

export async function getStaticPaths() {
  const clients = await getClients();
  return clients.map((c) => ({
    params: { slug: String(c.SLUG ?? "") },
    props: { client: c },
  }));
}

const { client } = Astro.props as { client: Record<string, unknown> };

const name = String(client["Head Artist"] ?? "");
// Management uses the `clientPresentation*` family of fields
const tagline = String(client.clientPresentationTitle ?? "");
const bioHtml = renderBio(String(client.clientPresentationString ?? ""));
const image = client.artistPicture_big
  ? String(client.artistPicture_big)
  : client.artistPicture_small
    ? String(client.artistPicture_small)
    : undefined;
// Management uses `tags` field; some records may also have `genre`
const tags = (client.tags ? String(client.tags).split(/\r|\n/).filter(Boolean)
  : client.genre ? String(client.genre).split(/\r|\n/).filter(Boolean)
  : []);
const manager = String(client.internalMgmntManager ?? client.internalAandR ?? "");
const managerEmail = String(
  client["Green_internalMgmntManagers::userEmail"] ?? client["Green_internalAandR::userEmail"] ?? "",
);
const ytOne = String(client.yotubeHighlight_one ?? "");
const ytTwo = String(client.yotubeHighlight_two ?? "");
const collectionId = String(client.collectionId ?? "").trim();

let merch: Awaited<ReturnType<typeof getProducts>> = [];
if (collectionId) {
  try { merch = await getProducts({ collectionId, limit: 8 }); } catch {}
}

let latestNews: Awaited<ReturnType<typeof getNewsForArtist>> = [];
try { latestNews = await getNewsForArtist(name, 3); } catch {}
---

<Base title={name} theme="management" description={tagline || `${name} | Ninetone Management`}>
  <section class="relative overflow-hidden bg-ninetone-navy py-20 text-white">
    {image && (
      <div class="absolute inset-0 opacity-20" style={`background-image: url(${image}); background-size: cover; background-position: center;`}></div>
    )}
    <div class="relative mx-auto max-w-7xl px-6">
      <p class="mb-2 text-xs uppercase tracking-wider opacity-70">
        <a href="/management/clients" class="hover:underline">← Clients</a>
      </p>
      <h1 class="font-display text-5xl">{name}</h1>
      {tagline && <p class="mt-2 max-w-3xl text-white/90">{tagline}</p>}
    </div>
  </section>

  <section class="bg-white py-16">
    <div class="mx-auto grid max-w-7xl grid-cols-1 gap-12 px-6 lg:grid-cols-[1fr_320px]">
      <article>
        <SocialRow
          spotify={String(client.url_spotify ?? "")}
          applemusic={String(client.url_applemusic ?? "")}
          youtube={String(client.url_youtube_link ?? client.url_youtube_music ?? "")}
          instagram={String(client.url_instagram ?? "")}
          tiktok={String(client.url_tiktok_artist ?? "")}
          facebook={String(client.url_facebook ?? "")}
          twitter={String(client.url_twitter ?? "")}
          size="sm"
        />

        {tags.length > 0 && (
          <div class="mt-6 flex flex-wrap gap-2">
            {tags.map((g) => (
              <span class="rounded bg-ninetone-navy/10 px-3 py-1 text-xs uppercase tracking-wider text-ninetone-navy">{g}</span>
            ))}
          </div>
        )}

        {image && (
          <img src={image} alt={name} class="mt-8 w-full rounded-sm object-cover" />
        )}

        <div class="prose mt-8 max-w-none text-neutral-800" set:html={bioHtml}></div>

        {(ytOne || ytTwo) && (
          <div class="mt-12">
            <h3 class="mb-4 font-display text-xl">Videos</h3>
            <div class="grid gap-4 sm:grid-cols-2">
              {[ytOne, ytTwo].filter(Boolean).map((url) => {
                const idMatch = url.match(/(?:v=|youtu\.be\/|embed\/)([\w-]{11})/);
                const id = idMatch ? idMatch[1] : null;
                return id ? (
                  <iframe src={`https://www.youtube.com/embed/${id}`} class="aspect-video w-full rounded" title={`${name} video`} loading="lazy" allowfullscreen></iframe>
                ) : null;
              })}
            </div>
          </div>
        )}
      </article>

      <aside class="flex flex-col gap-6">
        <div class="rounded bg-ninetone-navy p-5 text-white">
          <h3 class="font-display text-lg">Inquiries</h3>
          {manager && (
            <p class="mt-2 text-sm">
              Talent Manager: {managerEmail ? <a href={`mailto:${managerEmail}`} class="underline">{manager}</a> : manager}
            </p>
          )}
          <p class="mt-3 text-xs opacity-90">
            For inquiries about {name}, contact the Talent Manager for personalized assistance, or use our contact form.
          </p>
          <a href="/management/contact-management" class="mt-4 inline-flex items-center gap-2 rounded-sm bg-white px-3 py-1.5 text-xs font-semibold text-ninetone-navy">
            Contact <span aria-hidden>→</span>
          </a>
        </div>

        {latestNews.length > 0 && (
          <div>
            <h3 class="mb-2 font-display text-lg">Latest news</h3>
            <div class="grid gap-3">
              {latestNews.map((p) => (
                <NewsCard
                  title={String(p.Title ?? "")}
                  slug={String(p.slug ?? "")}
                  image={p.image_webp ? String(p.image_webp) : undefined}
                  excerpt={String(p.shortMessage ?? "").slice(0, 80)}
                  date={String(p.Date ?? "")}
                />
              ))}
            </div>
          </div>
        )}
      </aside>
    </div>
  </section>

  {merch.length > 0 && (
    <section class="bg-ninetone-ink py-16">
      <div class="mx-auto max-w-7xl px-6">
        <h2 class="font-display text-2xl uppercase tracking-wider text-white">{name} Merch</h2>
        <div class="mt-8 grid grid-cols-2 gap-4 md:grid-cols-3 lg:grid-cols-4">
          {merch.map((p) => <MerchCard product={p} />)}
        </div>
      </div>
    </section>
  )}
</Base>
