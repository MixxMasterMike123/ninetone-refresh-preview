---
import Base from "../../../layouts/Base.astro";
import StreamingRow from "../../../components/StreamingRow.astro";
import MerchCard from "../../../components/MerchCard.astro";
import NewsCard from "../../../components/NewsCard.astro";
import RosterStrip from "../../../components/RosterStrip.astro";
import { getClients, getNewsForArtist, pickRelatedArtists } from "../../../lib/ninetone";
import { getProducts } from "../../../lib/shopify";
import { renderBio } from "../../../lib/markdown";
import { url } from "../../../lib/url";

export async function getStaticPaths() {
  const clients = await getClients();
  return clients.map((c) => ({
    params: { slug: String(c.SLUG ?? "") },
    props: { client: c, allClients: clients },
  }));
}

const { client, allClients } = Astro.props as { client: Record<string, unknown>; allClients: Record<string, unknown>[] };

const name = String(client["Head Artist"] ?? "");
const tagline = String(client.clientPresentationTitle ?? "");
const bioHtml = renderBio(String(client.clientPresentationString ?? ""));
const heroImage = client.artistPicture_big
  ? String(client.artistPicture_big)
  : client.artistPicture_small
  ? String(client.artistPicture_small)
  : undefined;
const tags = (client.tags
  ? String(client.tags).split(/\r|\n|,/).map((s) => s.trim()).filter(Boolean)
  : client.genre
  ? String(client.genre).split(/\r|\n|,/).map((s) => s.trim()).filter(Boolean)
  : []);
const manager = String(client.internalMgmntManager ?? client.internalAandR ?? "");
const managerEmail = String(
  client["Green_internalMgmntManagers::userEmail"] ?? client["Green_internalAandR::userEmail"] ?? "",
);
const ytOne = String(client.yotubeHighlight_one ?? "");
const ytTwo = String(client.yotubeHighlight_two ?? "");
const collectionId = String(client.collectionId ?? "").trim();

const socials = {
  spotify: client.url_spotify ? String(client.url_spotify) : undefined,
  apple: client.url_applemusic ? String(client.url_applemusic) : undefined,
  amazon: client.url_amazon ? String(client.url_amazon) : undefined,
  youtubeMusic: client.url_youtube_music ? String(client.url_youtube_music) : undefined,
  youtube: client.url_youtube_link ? String(client.url_youtube_link) : undefined,
  instagram: client.url_instagram ? String(client.url_instagram) : undefined,
  tiktok: client.url_tiktok_artist ? String(client.url_tiktok_artist) : undefined,
  twitter: client.url_twitter ? String(client.url_twitter) : undefined,
  facebook: client.url_facebook ? String(client.url_facebook) : undefined,
  soundcloud: undefined,
};

let merch: Awaited<ReturnType<typeof getProducts>> = [];
if (collectionId) {
  try { merch = await getProducts({ collectionId, limit: 8 }); } catch {}
}

let latestNews: Awaited<ReturnType<typeof getNewsForArtist>> = [];
try { latestNews = await getNewsForArtist(name, 4); } catch {}

// "In good company" — same-tag clients ranked by overlap, padded with random
// others if there aren't enough matches.
function clientTagsOf(c: Record<string, unknown>): string[] {
  const raw = (c.tags ?? c.genre ?? "") as string;
  return String(raw).split(/\r|\n|,/).map((s) => s.trim()).filter(Boolean);
}
const related = pickRelatedArtists(client, allClients, clientTagsOf, 12);

const ytLinks = [ytOne, ytTwo].filter(Boolean);
---

<Base title={name} theme="management" description={tagline || `${name} | Ninetone Management`}>
  <section class="bg-ninetone-paper">
    <div class="mx-auto max-w-7xl px-6 pb-12 pt-12 md:pt-16">
      <p class="mb-8">
        <a href={url("/management/clients")} class="kicker text-ninetone-ink/55 hover:text-ninetone-ink">← Management · Clients</a>
      </p>

      <div class="grid gap-10 md:grid-cols-12 md:gap-16">
        <aside class="md:col-span-5 lg:col-span-5">
          <div class="md:sticky md:top-24">
            <div class="fm-img-frame relative aspect-[4/5] w-full overflow-hidden bg-ninetone-paper-warm">
              {heroImage && (
                <img
                  src={heroImage}
                  alt={name}
                  class="fm-img h-full w-full object-cover"
                  onload="this.classList.add('is-loaded'); this.closest('.fm-img-frame')?.classList.add('is-ready')"
                />
              )}
              <span class="absolute left-0 top-0 h-1 w-16 bg-ninetone-navy" aria-hidden></span>
            </div>
            <div class="mt-6 hidden md:block">
              <StreamingRow socials={socials} />
            </div>
          </div>
        </aside>

        <div class="md:col-span-7 lg:col-span-7">
          <span class="kicker text-ninetone-navy">Management — Client</span>
          <h1 class="mt-4 font-display text-[clamp(3rem,8vw,7rem)] leading-[0.9] tracking-[-0.045em]">{name}</h1>

          {tagline && (
            <p class="mt-6 max-w-xl font-display text-2xl italic leading-snug tracking-tight text-ninetone-ink/75 md:text-3xl">
              {tagline}
            </p>
          )}

          {tags.length > 0 && (
            <div class="mt-6 flex flex-wrap gap-x-4 gap-y-2 text-xs uppercase tracking-[0.16em] text-ninetone-ink/60">
              {tags.slice(0, 6).map((g, i) => (
                <span>{i > 0 && <span aria-hidden class="mr-4 opacity-40">·</span>}{g}</span>
              ))}
            </div>
          )}

          <div class="mt-8 md:hidden">
            <StreamingRow socials={socials} />
          </div>

          <div class="mt-12 prose lede max-w-none" set:html={bioHtml}></div>

          {ytLinks.length > 0 && (
            <div class="mt-16 border-t border-ninetone-rule pt-10">
              <span class="kicker text-ninetone-ink/55">Watch</span>
              <div class="mt-6 grid gap-4 sm:grid-cols-2">
                {ytLinks.map((url) => {
                  const idMatch = url.match(/(?:v=|youtu\.be\/|embed\/)([\w-]{11})/);
                  const id = idMatch ? idMatch[1] : null;
                  return id ? (
                    <iframe src={`https://www.youtube.com/embed/${id}`} class="aspect-video w-full" title={`${name} video`} loading="lazy" allowfullscreen></iframe>
                  ) : null;
                })}
              </div>
            </div>
          )}

          {(manager || managerEmail) && (
            <div class="mt-16 border-t border-ninetone-rule pt-10">
              <span class="kicker text-ninetone-navy">Represented by</span>
              <div class="mt-4 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
                <div>
                  <p class="font-display text-2xl font-medium leading-tight tracking-tight">{manager || "Ninetone Management"}</p>
                  {managerEmail && (
                    <a href={`mailto:${managerEmail}`} class="mt-2 inline-block text-sm text-ninetone-ink/70 underline-offset-4 hover:underline">
                      {managerEmail}
                    </a>
                  )}
                </div>
                <a
                  href={url("/management/contact-management")}
                  class="inline-flex items-center gap-2 self-start bg-ninetone-navy px-4 py-3 text-sm font-semibold text-ninetone-paper transition-colors hover:bg-ninetone-navy-dark"
                >
                  Get in touch <span aria-hidden>→</span>
                </a>
              </div>
            </div>
          )}

          {latestNews.length > 0 && (
            <div class="mt-16 border-t border-ninetone-rule pt-10">
              <span class="kicker text-ninetone-ink/55">In the news</span>
              <ul class="mt-6 grid gap-x-8 gap-y-10 md:grid-cols-2">
                {latestNews.map((p) => (
                  <li>
                    <NewsCard
                      title={String(p.Title ?? "")}
                      slug={String(p.slug ?? "")}
                      image={p.image_webp ? String(p.image_webp) : undefined}
                      date={String(p.Date ?? "")}
                      category={String(p.category ?? "")}
                      size="sm"
                    />
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  {merch.length > 0 && (
    <section class="bg-ninetone-paper-warm py-20">
      <div class="mx-auto max-w-7xl px-6">
        <div class="mb-10">
          <span class="kicker text-ninetone-navy">Merch</span>
          <h2 class="mt-3 font-display text-4xl leading-[1.05] tracking-tight md:text-5xl">{name} — official.</h2>
        </div>
        <div class="grid grid-cols-2 gap-x-6 gap-y-12 md:grid-cols-3 lg:grid-cols-4">
          {merch.map((p) => <MerchCard product={p} />)}
        </div>
      </div>
    </section>
  )}

  {related.length > 0 && (
    <RosterStrip
      artists={related}
      theme="management"
      hrefBase="/management/clients"
      kicker="More from Management"
      heading="In good company."
      cta={{ label: "All clients", href: "/management/clients" }}
    />
  )}
</Base>
