---
import Base from "../../layouts/Base.astro";
import SplitPortalHero from "../../components/SplitPortalHero.astro";
import WebPostsSection from "../../components/WebPostsSection.astro";
import LatestNewsSection from "../../components/LatestNewsSection.astro";
import { getWebPostSection } from "../../lib/ninetone";

const webPosts = await getWebPostSection("Ninetone Management");
---

<Base title="Ninetone Management" theme="management">
  <SplitPortalHero
    theme="management"
    kicker="Ninetone Management"
    left={{
      href: "/management/clients",
      label: "Clients",
      blurb: "A roster of Sweden's most extraordinary creators and influencers.",
      bgImage: "/images/clientsBanner-management.png",
    }}
    right={{
      href: "/team",
      label: "The team",
      blurb: "Day-to-day partners — the people building careers alongside our clients.",
      bgImage: "/images/meetTheTeamBanner.png",
    }}
  />
  <WebPostsSection data={webPosts} />
  <LatestNewsSection />
</Base>
