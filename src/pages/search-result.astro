---
import Base from "../layouts/Base.astro";
---

<Base title="Search">
  <section class="bg-ninetone-ink py-12 text-white">
    <div class="mx-auto max-w-7xl px-6">
      <h1 class="font-display text-5xl">Search</h1>
      <form method="get" action="/search-result" class="mt-6 flex max-w-xl gap-2">
        <input
          id="search-input"
          type="search"
          name="q"
          placeholder="Search artists, news, team…"
          class="w-full rounded-sm border border-white/20 bg-white/10 px-4 py-2 text-white placeholder-white/50 focus:border-white focus:outline-none"
          autocomplete="off"
        />
        <button type="submit" class="rounded-sm bg-white px-5 py-2 text-sm font-semibold text-ninetone-ink hover:bg-white/90">
          Go
        </button>
      </form>
      <p id="search-status" class="mt-3 text-sm text-white/60">Type a query and press Go.</p>
    </div>
  </section>

  <section class="bg-ninetone-ink pb-20 text-white">
    <div id="search-results" class="mx-auto max-w-7xl px-6"></div>
  </section>
</Base>

<script>
  import Fuse from "fuse.js";

  type SearchSection = "records" | "previous" | "management" | "nation" | "team" | "news";
  type SearchEntry = {
    section: SearchSection;
    name: string;
    blurb: string;
    tags: string[];
    href: string;
    image?: string;
  };

  const SECTION_LABELS: Record<SearchSection, string> = {
    records: "Ninetone Records",
    previous: "Previous Artists",
    management: "Ninetone Management",
    nation: "Ninetone Nation",
    team: "Team",
    news: "News",
  };

  const SECTION_ORDER: SearchSection[] = ["records", "management", "nation", "previous", "team", "news"];

  let indexPromise: Promise<SearchEntry[]> | null = null;
  function loadIndex(): Promise<SearchEntry[]> {
    if (!indexPromise) {
      indexPromise = fetch("/search-index.json").then((r) => r.json());
    }
    return indexPromise;
  }

  function escapeHtml(s: string): string {
    return s
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;");
  }

  function renderResults(query: string, hits: SearchEntry[]): string {
    if (hits.length === 0) {
      return `<p class="text-white/70">No results for <strong>${escapeHtml(query)}</strong>.</p>`;
    }

    const grouped = new Map<SearchSection, SearchEntry[]>();
    for (const h of hits) {
      const arr = grouped.get(h.section) ?? [];
      arr.push(h);
      grouped.set(h.section, arr);
    }

    const sections = SECTION_ORDER.filter((s) => grouped.has(s));
    return sections
      .map((s) => {
        const items = grouped.get(s)!;
        const cards = items
          .map(
            (e) => `
              <a href="${escapeHtml(e.href)}" class="group block rounded-sm border border-white/10 bg-white/5 p-4 hover:border-white/30 hover:bg-white/10">
                <div class="flex gap-4">
                  ${e.image ? `<img src="${escapeHtml(e.image)}" alt="" class="h-16 w-16 shrink-0 rounded-sm object-cover" loading="lazy" />` : ""}
                  <div class="min-w-0">
                    <h3 class="truncate font-semibold text-white group-hover:underline">${escapeHtml(e.name)}</h3>
                    ${e.blurb ? `<p class="mt-1 line-clamp-2 text-sm text-white/70">${escapeHtml(e.blurb)}</p>` : ""}
                    ${e.tags.length ? `<div class="mt-2 flex flex-wrap gap-1">${e.tags.slice(0, 3).map((t) => `<span class="rounded bg-white/10 px-2 py-0.5 text-xs uppercase tracking-wider text-white/70">${escapeHtml(t)}</span>`).join("")}</div>` : ""}
                  </div>
                </div>
              </a>`,
          )
          .join("");
        return `
          <div class="mb-10">
            <h2 class="mb-4 text-xs font-semibold uppercase tracking-wider text-white/60">
              ${SECTION_LABELS[s]} <span class="text-white/40">(${items.length})</span>
            </h2>
            <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">${cards}</div>
          </div>`;
      })
      .join("");
  }

  async function runSearch(query: string) {
    const status = document.getElementById("search-status");
    const out = document.getElementById("search-results");
    if (!status || !out) return;

    if (!query) {
      status.textContent = "Type a query and press Go.";
      out.innerHTML = "";
      return;
    }

    status.textContent = "Searching…";
    out.innerHTML = "";

    const data = await loadIndex();
    const fuse = new Fuse(data, {
      keys: [
        { name: "name", weight: 0.6 },
        { name: "blurb", weight: 0.25 },
        { name: "tags", weight: 0.15 },
      ],
      threshold: 0.35,
      ignoreLocation: true,
      minMatchCharLength: 2,
    });

    const results = fuse.search(query, { limit: 100 }).map((r) => r.item);
    status.textContent = `${results.length} result${results.length === 1 ? "" : "s"} for "${query}"`;
    out.innerHTML = renderResults(query, results);
  }

  const params = new URLSearchParams(window.location.search);
  const initialQuery = params.get("q")?.trim() ?? "";
  const input = document.getElementById("search-input") as HTMLInputElement | null;
  if (input && initialQuery) input.value = initialQuery;
  if (initialQuery) runSearch(initialQuery);
</script>
