---
import Base from "../layouts/Base.astro";
import { url } from "../lib/url";
---

<Base title="Search">
  <section class="bg-ninetone-paper">
    <div class="mx-auto max-w-7xl px-6 pb-12 pt-16 md:pt-24">
      <span class="kicker text-ninetone-ink/55">Search</span>
      <h1 class="mt-4 font-display text-[clamp(2.75rem,7vw,6rem)] leading-[0.95] tracking-[-0.035em]">
        Find anything.
      </h1>
      <p class="mt-4 max-w-xl text-base text-ninetone-ink/65">
        Press <kbd class="rounded border border-ninetone-ink/15 px-1.5 py-0.5 text-xs font-medium text-ninetone-ink/70">⌘K</kbd> from anywhere on the site to open the command palette.
      </p>

      <form method="get" action={url("/search-result")} class="mt-10 flex max-w-2xl items-center gap-3 border-b border-ninetone-ink/20 pb-3">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5 text-ninetone-ink/55">
          <circle cx="11" cy="11" r="7"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
        <input
          id="search-input"
          type="search"
          name="q"
          placeholder="Search artists, news, team…"
          class="w-full border-0 bg-transparent font-display text-2xl text-ninetone-ink placeholder-ninetone-ink/35 focus:outline-none"
          autocomplete="off"
        />
        <button type="submit" class="bg-ninetone-ink px-4 py-2 text-sm font-semibold text-ninetone-paper transition-colors hover:bg-ninetone-ink-soft">
          Search
        </button>
      </form>
      <p id="search-status" class="mt-4 text-xs uppercase tracking-[0.16em] text-ninetone-ink/55">Type a query and press search.</p>
    </div>
  </section>

  <section class="bg-ninetone-paper pb-24">
    <div id="search-results" class="mx-auto max-w-7xl px-6"></div>
  </section>
</Base>

<script>
  import Fuse from "fuse.js";

  type SearchSection = "records" | "previous" | "management" | "nation" | "team" | "news";
  type SearchEntry = {
    section: SearchSection;
    name: string;
    blurb: string;
    tags: string[];
    href: string;
    image?: string;
  };

  const SECTION_LABELS: Record<SearchSection, string> = {
    records: "Records",
    previous: "Previous artists",
    management: "Management",
    nation: "Nation",
    team: "Team",
    news: "News",
  };

  const SECTION_ORDER: SearchSection[] = ["records", "management", "nation", "previous", "team", "news"];

  let indexPromise: Promise<SearchEntry[]> | null = null;
  function loadIndex(): Promise<SearchEntry[]> {
    if (!indexPromise) {
      const base = import.meta.env.BASE_URL.replace(/\/$/, "");
      indexPromise = fetch(`${base}/search-index.json`).then((r) => r.json());
    }
    return indexPromise;
  }

  function escapeHtml(s: string): string {
    return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
  }

  function renderResults(query: string, hits: SearchEntry[]): string {
    if (hits.length === 0) {
      return `<p class="text-base text-ninetone-ink/65">No results for <strong>${escapeHtml(query)}</strong>.</p>`;
    }

    const grouped = new Map<SearchSection, SearchEntry[]>();
    for (const h of hits) {
      const arr = grouped.get(h.section) ?? [];
      arr.push(h);
      grouped.set(h.section, arr);
    }

    const sections = SECTION_ORDER.filter((s) => grouped.has(s));
    return sections
      .map((s) => {
        const items = grouped.get(s)!;
        const cards = items
          .map(
            (e) => `
              <a href="${escapeHtml(e.href)}" class="group flex flex-col gap-3 border-t border-ninetone-rule pt-4 transition-colors">
                ${e.image ? `<div class="aspect-[4/3] w-full overflow-hidden bg-ninetone-paper-warm"><img src="${escapeHtml(e.image)}" alt="" class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.04]" loading="lazy" /></div>` : ""}
                <div>
                  <h3 class="font-display text-xl font-medium leading-tight tracking-tight transition-colors group-hover:opacity-70">${escapeHtml(e.name)}</h3>
                  ${e.blurb ? `<p class="mt-2 line-clamp-2 text-sm text-ninetone-ink/65">${escapeHtml(e.blurb)}</p>` : ""}
                  ${e.tags.length ? `<div class="mt-3 flex flex-wrap gap-x-3 gap-y-1 text-[0.6875rem] uppercase tracking-[0.12em] text-ninetone-ink/55">${e.tags.slice(0, 3).map((t, i) => `${i > 0 ? '<span class="opacity-40">·</span>' : ""}<span>${escapeHtml(t)}</span>`).join("")}</div>` : ""}
                </div>
              </a>`,
          )
          .join("");
        return `
          <div class="mb-12">
            <div class="mb-6 flex items-center justify-between">
              <span class="kicker text-ninetone-ink/55">${SECTION_LABELS[s]}</span>
              <span class="text-xs text-ninetone-ink/55">${items.length}</span>
            </div>
            <div class="grid gap-x-8 gap-y-12 md:grid-cols-3 lg:grid-cols-4">${cards}</div>
          </div>`;
      })
      .join("");
  }

  async function runSearch(query: string) {
    const status = document.getElementById("search-status");
    const out = document.getElementById("search-results");
    if (!status || !out) return;

    if (!query) {
      status.textContent = "Type a query and press search.";
      out.innerHTML = "";
      return;
    }

    status.textContent = "Searching…";
    out.innerHTML = "";

    const data = await loadIndex();
    const fuse = new Fuse(data, {
      keys: [
        { name: "name", weight: 0.6 },
        { name: "blurb", weight: 0.25 },
        { name: "tags", weight: 0.15 },
      ],
      threshold: 0.35,
      ignoreLocation: true,
      minMatchCharLength: 2,
    });

    const results = fuse.search(query, { limit: 100 }).map((r) => r.item);
    status.textContent = `${results.length} result${results.length === 1 ? "" : "s"} for "${query}"`;
    out.innerHTML = renderResults(query, results);
  }

  const params = new URLSearchParams(window.location.search);
  const initialQuery = params.get("q")?.trim() ?? "";
  const input = document.getElementById("search-input") as HTMLInputElement | null;
  if (input && initialQuery) input.value = initialQuery;
  if (initialQuery) runSearch(initialQuery);
</script>
