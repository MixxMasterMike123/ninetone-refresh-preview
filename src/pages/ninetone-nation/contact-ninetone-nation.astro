---
import Base from "../../layouts/Base.astro";
import ContactForm from "../../components/ContactForm.astro";
---

<Base title="Booking request" theme="nation">
  <ContactForm
    theme="nation"
    kicker="Nation — Booking"
    heading="Book your next moment."
    tagline="Sweden's leading artists, hosts, and entertainers."
    blurb="Tell us the artist, the date, the room, and the budget — we'll get back with availability, fee structure, and technical needs within one business day."
    formTitle="Send a booking request."
    formBlurb="The more context you give us, the faster we can confirm."
    submitLabel="Send request"
    fields={[
      { type: "text", name: "name", label: "Your name", placeholder: "Full name", required: true },
      { type: "email", name: "email", label: "Email", placeholder: "you@company.com", required: true },
      { type: "text", name: "company", label: "Company / event", placeholder: "Optional" },
      { type: "text", name: "date", label: "Event date", placeholder: "Optional" },
      { type: "textarea", name: "details", label: "Details", placeholder: "Which artist? Date, location, audience size, format…", rows: 5, required: true },
    ]}
  />
</Base>
