---
import Base from "../../layouts/Base.astro";
import StreamingRow from "../../components/StreamingRow.astro";
import NewsCard from "../../components/NewsCard.astro";
import MerchCard from "../../components/MerchCard.astro";
import RosterStrip from "../../components/RosterStrip.astro";
import { getBookingRoster, getAllActiveBookingSlugs, getNewsForArtist, pickRelatedArtists } from "../../lib/ninetone";
import { fmFind } from "../../lib/filemaker";
import { getProducts } from "../../lib/shopify";
import { renderBio } from "../../lib/markdown";
import { url } from "../../lib/url";

// Generate a page for every Active talent listed on the booking page.
// Source of truth = the curated BOOKING_TAG portal set, filtered to
// filterActive=Active. Keeps the linked-from-list set and the page-exists
// set in lockstep; no orphan links, no 404s.
export async function getStaticPaths() {
  const [slugs, roster] = await Promise.all([
    getAllActiveBookingSlugs(),
    getBookingRoster().catch(() => [] as Record<string, unknown>[]),
  ]);

  // Most curated talents also exist in getBookingRoster() (the strict query)
  // — for those we already have the full record. For the rest (booking-only
  // talents who pass curation + active but don't pass the roster's stricter
  // filters), fetch their record by slug from API_Booking directly.
  const rosterBySlug = new Map<string, Record<string, unknown>>();
  for (const a of roster) {
    const s = String(a.SLUG ?? "");
    if (s) rosterBySlug.set(s, a);
  }

  const missing = slugs.filter((s) => !rosterBySlug.has(s));
  const extras = await Promise.all(
    missing.map((slug) =>
      fmFind<Record<string, unknown>>("API_Booking", {
        query: [{ SLUG: `==${slug}`, filterActive: "==Active" }],
        limit: 1,
      })
        .then((rows) => rows[0])
        .catch(() => undefined),
    ),
  );
  for (const r of extras) {
    if (r && r.SLUG) rosterBySlug.set(String(r.SLUG), r);
  }

  // Build the union — used as allRoster for "More from Nation" related strip.
  const allRoster = [...rosterBySlug.values()];

  return slugs
    .map((slug) => rosterBySlug.get(slug))
    .filter((e): e is Record<string, unknown> => Boolean(e))
    .map((entertainer) => ({
      params: { slug: String(entertainer.SLUG ?? "") },
      props: { entertainer, allRoster },
    }));
}

const { entertainer: e, allRoster } = Astro.props as { entertainer: Record<string, unknown>; allRoster: Record<string, unknown>[] };

const name = String(e["Head Artist"] ?? "");
const tagline = String(e.bookingPresentationTitle ?? "");
const bioHtml = renderBio(String(e.bookingPresentationString ?? ""));
const heroImage = e.artistPicture_big
  ? String(e.artistPicture_big)
  : e.artistPicture_small
  ? String(e.artistPicture_small)
  : undefined;
const tags = (e.tagBooking
  ? String(e.tagBooking).split(/\r|\n|,/).map((s) => s.trim()).filter(Boolean)
  : e.tags
  ? String(e.tags).split(/\r|\n|,/).map((s) => s.trim()).filter(Boolean)
  : e.genre
  ? String(e.genre).split(/\r|\n|,/).map((s) => s.trim()).filter(Boolean)
  : []);
const ytOne = String(e.yotubeHighlight_one ?? "");
const ytTwo = String(e.yotubeHighlight_two ?? "");
const collectionId = String(e.collectionId ?? "").trim();

const socials = {
  spotify: e.url_spotify ? String(e.url_spotify) : undefined,
  apple: e.url_applemusic ? String(e.url_applemusic) : undefined,
  amazon: e.url_amazon ? String(e.url_amazon) : undefined,
  youtubeMusic: e.url_youtube_music ? String(e.url_youtube_music) : undefined,
  youtube: e.url_youtube_link ? String(e.url_youtube_link) : undefined,
  instagram: e.url_instagram ? String(e.url_instagram) : undefined,
  tiktok: e.url_tiktok_artist ? String(e.url_tiktok_artist) : undefined,
  twitter: e.url_twitter ? String(e.url_twitter) : undefined,
  facebook: e.url_facebook ? String(e.url_facebook) : undefined,
  soundcloud: undefined,
};

let merch: Awaited<ReturnType<typeof getProducts>> = [];
if (collectionId) {
  try { merch = await getProducts({ collectionId, limit: 8 }); } catch {}
}

let latestNews: Awaited<ReturnType<typeof getNewsForArtist>> = [];
try { latestNews = await getNewsForArtist(name, 4); } catch {}

// "In good company" — same-tag entertainers ranked by overlap, padded with
// random others if there aren't enough matches.
function nationTagsOf(r: Record<string, unknown>): string[] {
  const raw = (r.tagBooking ?? r.tags ?? r.genre ?? "") as string;
  return String(raw).split(/\r|\n|,/).map((s) => s.trim()).filter(Boolean);
}
const related = pickRelatedArtists(e, allRoster, nationTagsOf, 12);

const ytLinks = [ytOne, ytTwo].filter(Boolean);
---

<Base title={name} theme="nation" description={tagline || `${name} | Ninetone Nation`}>
  <section class="bg-ninetone-paper">
    <div class="mx-auto max-w-7xl px-6 pb-12 pt-12 md:pt-16">
      <p class="mb-8">
        <a href={url("/ninetone-nation/booking")} class="kicker text-ninetone-ink/55 hover:text-ninetone-ink">← Nation · Booking</a>
      </p>

      <div class="grid gap-10 md:grid-cols-12 md:gap-16">
        <aside class="md:col-span-5 lg:col-span-5">
          <div class="md:sticky md:top-24">
            <div class="fm-img-frame relative aspect-[4/5] w-full overflow-hidden bg-ninetone-paper-warm">
              {heroImage && (
                <img
                  src={heroImage}
                  alt={name}
                  class="fm-img h-full w-full object-cover"
                  onload="this.classList.add('is-loaded'); this.closest('.fm-img-frame')?.classList.add('is-ready')"
                />
              )}
              <span class="absolute left-0 top-0 h-1 w-16 bg-ninetone-green" aria-hidden></span>
            </div>
            <div class="mt-6 hidden md:block">
              <StreamingRow socials={socials} />
            </div>
            <a
              href={url("/ninetone-nation/contact-ninetone-nation")}
              class="mt-6 hidden w-full items-center justify-center gap-2 bg-ninetone-green px-4 py-3 text-sm font-semibold text-ninetone-paper transition-colors hover:bg-ninetone-green-dark md:inline-flex"
            >
              Book {name} <span aria-hidden>→</span>
            </a>
          </div>
        </aside>

        <div class="md:col-span-7 lg:col-span-7">
          <span class="kicker text-ninetone-green">Nation — Booking</span>
          <h1 class="mt-4 font-display text-[clamp(3rem,8vw,7rem)] leading-[0.9] tracking-[-0.045em]">{name}</h1>

          {tagline && (
            <p class="mt-6 max-w-xl font-display text-2xl italic leading-snug tracking-tight text-ninetone-ink/75 md:text-3xl">
              {tagline}
            </p>
          )}

          {tags.length > 0 && (
            <div class="mt-6 flex flex-wrap gap-x-4 gap-y-2 text-xs uppercase tracking-[0.16em] text-ninetone-ink/60">
              {tags.slice(0, 6).map((g, i) => (
                <span>{i > 0 && <span aria-hidden class="mr-4 opacity-40">·</span>}{g}</span>
              ))}
            </div>
          )}

          <div class="mt-8 md:hidden">
            <StreamingRow socials={socials} />
          </div>

          <a
            href={url("/ninetone-nation/contact-ninetone-nation")}
            class="mt-6 inline-flex items-center gap-2 bg-ninetone-green px-4 py-3 text-sm font-semibold text-ninetone-paper transition-colors hover:bg-ninetone-green-dark md:hidden"
          >
            Book {name} <span aria-hidden>→</span>
          </a>

          <div class="mt-12 prose lede max-w-none" set:html={bioHtml}></div>

          {ytLinks.length > 0 && (
            <div class="mt-16 border-t border-ninetone-rule pt-10">
              <span class="kicker text-ninetone-ink/55">Watch</span>
              <div class="mt-6 grid gap-4 sm:grid-cols-2">
                {ytLinks.map((url) => {
                  const idMatch = url.match(/(?:v=|youtu\.be\/|embed\/)([\w-]{11})/);
                  const id = idMatch ? idMatch[1] : null;
                  return id ? (
                    <iframe src={`https://www.youtube.com/embed/${id}`} class="aspect-video w-full" title={`${name} video`} loading="lazy" allowfullscreen></iframe>
                  ) : null;
                })}
              </div>
            </div>
          )}

          <!-- Booking technical / inquiry block -->
          <div class="mt-16 border-t border-ninetone-rule pt-10">
            <span class="kicker text-ninetone-green">Booking</span>
            <div class="mt-4 grid gap-6 md:grid-cols-2">
              <div>
                <p class="font-display text-2xl font-medium leading-tight tracking-tight">Ready to book {name}?</p>
                <p class="mt-3 text-sm text-ninetone-ink/65">
                  Get availability, fee structure, and technical requirements within one business day.
                </p>
              </div>
              <div class="flex flex-col gap-3 md:items-end md:text-right">
                <a
                  href={url("/ninetone-nation/contact-ninetone-nation")}
                  class="inline-flex items-center gap-2 self-start bg-ninetone-green px-4 py-3 text-sm font-semibold text-ninetone-paper transition-colors hover:bg-ninetone-green-dark md:self-end"
                >
                  Send booking request <span aria-hidden>→</span>
                </a>
                <a href="mailto:booking@ninetone.com" class="text-sm text-ninetone-ink/70 underline-offset-4 hover:underline">
                  booking@ninetone.com
                </a>
              </div>
            </div>
          </div>

          {latestNews.length > 0 && (
            <div class="mt-16 border-t border-ninetone-rule pt-10">
              <span class="kicker text-ninetone-ink/55">In the news</span>
              <ul class="mt-6 grid gap-x-8 gap-y-10 md:grid-cols-2">
                {latestNews.map((p) => (
                  <li>
                    <NewsCard
                      title={String(p.Title ?? "")}
                      slug={String(p.slug ?? "")}
                      image={p.image_webp ? String(p.image_webp) : undefined}
                      date={String(p.Date ?? "")}
                      category={String(p.category ?? "")}
                      hasVideo={["ytLinkA","ytLinkB","ytLinkC","ytLinkD"].some((k) => typeof (p as Record<string, unknown>)[k] === "string" && ((p as Record<string, unknown>)[k] as string).trim().length > 0)}
                      size="sm"
                    />
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  {merch.length > 0 && (
    <section class="bg-ninetone-paper-warm py-20">
      <div class="mx-auto max-w-7xl px-6">
        <div class="mb-10">
          <span class="kicker text-ninetone-green">Merch</span>
          <h2 class="mt-3 font-display text-4xl leading-[1.05] tracking-tight md:text-5xl">{name} — official.</h2>
        </div>
        <div class="grid grid-cols-2 gap-x-6 gap-y-12 md:grid-cols-3 lg:grid-cols-4">
          {merch.map((p) => <MerchCard product={p} />)}
        </div>
      </div>
    </section>
  )}

  {related.length > 0 && (
    <RosterStrip
      artists={related}
      theme="nation"
      hrefBase="/ninetone-nation"
      kicker="More from Nation"
      heading="Available now."
      cta={{ label: "All entertainers", href: "/ninetone-nation/booking" }}
    />
  )}
</Base>
