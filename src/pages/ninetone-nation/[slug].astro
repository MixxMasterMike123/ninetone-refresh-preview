---
import Base from "../../layouts/Base.astro";
import SocialRow from "../../components/SocialRow.astro";
import NewsCard from "../../components/NewsCard.astro";
import MerchCard from "../../components/MerchCard.astro";
import { getBookingRoster, getNewsForArtist } from "../../lib/ninetone";
import { getProducts } from "../../lib/shopify";
import { renderBio } from "../../lib/markdown";

export async function getStaticPaths() {
  const roster = await getBookingRoster();
  return roster.map((a) => ({
    params: { slug: String(a.SLUG ?? "") },
    props: { entertainer: a },
  }));
}

const { entertainer: e } = Astro.props as { entertainer: Record<string, unknown> };

const name = String(e["Head Artist"] ?? "");
// Nation uses the `bookingPresentation*` family of fields
const tagline = String(e.bookingPresentationTitle ?? "");
const bioHtml = renderBio(String(e.bookingPresentationString ?? ""));
const image = e.artistPicture_big ? String(e.artistPicture_big) : e.artistPicture_small ? String(e.artistPicture_small) : undefined;
const tags = (e.tags ? String(e.tags).split(/\r|\n/).filter(Boolean)
  : e.genre ? String(e.genre).split(/\r|\n/).filter(Boolean)
  : []);
const ytOne = String(e.yotubeHighlight_one ?? "");
const ytTwo = String(e.yotubeHighlight_two ?? "");
const collectionId = String(e.collectionId ?? "").trim();

let merch: Awaited<ReturnType<typeof getProducts>> = [];
if (collectionId) {
  try { merch = await getProducts({ collectionId, limit: 8 }); } catch {}
}

let latestNews: Awaited<ReturnType<typeof getNewsForArtist>> = [];
try { latestNews = await getNewsForArtist(name, 3); } catch {}
---

<Base title={name} theme="nation" description={tagline || `${name} | Ninetone Nation`}>
  <section class="relative overflow-hidden bg-ninetone-green py-20 text-white">
    {image && (
      <div class="absolute inset-0 opacity-25" style={`background-image: url(${image}); background-size: cover; background-position: center;`}></div>
    )}
    <div class="relative mx-auto max-w-7xl px-6">
      <p class="mb-2 text-xs uppercase tracking-wider opacity-80">
        <a href="/ninetone-nation/booking" class="hover:underline">← Boka</a>
      </p>
      <h1 class="font-display text-5xl">{name}</h1>
      {tagline && <p class="mt-2 max-w-3xl text-white/90">{tagline}</p>}
      <a href="/ninetone-nation/contact-ninetone-nation" class="mt-6 inline-flex items-center gap-2 rounded-sm bg-white px-4 py-2 text-sm font-semibold text-ninetone-green">
        Boka {name} <span aria-hidden>→</span>
      </a>
    </div>
  </section>

  <section class="bg-ninetone-card-sage py-16">
    <div class="mx-auto grid max-w-7xl grid-cols-1 gap-12 px-6 lg:grid-cols-[1fr_320px]">
      <article class="text-ninetone-ink">
        <SocialRow
          spotify={String(e.url_spotify ?? "")}
          applemusic={String(e.url_applemusic ?? "")}
          youtube={String(e.url_youtube_link ?? e.url_youtube_music ?? "")}
          instagram={String(e.url_instagram ?? "")}
          tiktok={String(e.url_tiktok_artist ?? "")}
          facebook={String(e.url_facebook ?? "")}
          twitter={String(e.url_twitter ?? "")}
          size="sm"
        />

        {tags.length > 0 && (
          <div class="mt-6 flex flex-wrap gap-2">
            {tags.map((g) => (
              <span class="rounded bg-ninetone-green/20 px-3 py-1 text-xs uppercase tracking-wider text-ninetone-green-dark">{g}</span>
            ))}
          </div>
        )}

        {image && (
          <img src={image} alt={name} class="mt-8 w-full rounded-sm object-cover" />
        )}

        <div class="prose mt-8 max-w-none text-ninetone-ink" set:html={bioHtml}></div>

        {(ytOne || ytTwo) && (
          <div class="mt-12">
            <h3 class="mb-4 font-display text-xl">Videos</h3>
            <div class="grid gap-4 sm:grid-cols-2">
              {[ytOne, ytTwo].filter(Boolean).map((url) => {
                const idMatch = url.match(/(?:v=|youtu\.be\/|embed\/)([\w-]{11})/);
                const id = idMatch ? idMatch[1] : null;
                return id ? (
                  <iframe src={`https://www.youtube.com/embed/${id}`} class="aspect-video w-full rounded" title={`${name} video`} loading="lazy" allowfullscreen></iframe>
                ) : null;
              })}
            </div>
          </div>
        )}
      </article>

      <aside class="flex flex-col gap-6">
        <div class="rounded bg-ninetone-green p-5 text-white">
          <h3 class="font-display text-lg">Bokningsförfrågan</h3>
          <p class="mt-2 text-sm opacity-90">Boka {name} via länken nedan eller maila till booking@ninetone.com</p>
          <a href="/ninetone-nation/contact-ninetone-nation" class="mt-4 inline-flex items-center gap-2 rounded-sm bg-white px-3 py-1.5 text-xs font-semibold text-ninetone-green">
            Boka {name} <span aria-hidden>→</span>
          </a>
        </div>

        {latestNews.length > 0 && (
          <div>
            <h3 class="mb-2 font-display text-lg">Senaste nyheterna</h3>
            <div class="grid gap-3">
              {latestNews.map((p) => (
                <NewsCard
                  title={String(p.Title ?? "")}
                  slug={String(p.slug ?? "")}
                  image={p.image_webp ? String(p.image_webp) : undefined}
                  excerpt={String(p.shortMessage ?? "").slice(0, 80)}
                  date={String(p.Date ?? "")}
                  lang="sv"
                />
              ))}
            </div>
          </div>
        )}
      </aside>
    </div>
  </section>

  {merch.length > 0 && (
    <section class="bg-ninetone-ink py-16">
      <div class="mx-auto max-w-7xl px-6">
        <h2 class="font-display text-2xl uppercase tracking-wider text-white">{name} Merch</h2>
        <div class="mt-8 grid grid-cols-2 gap-4 md:grid-cols-3 lg:grid-cols-4">
          {merch.map((p) => <MerchCard product={p} lang="sv" />)}
        </div>
      </div>
    </section>
  )}
</Base>
