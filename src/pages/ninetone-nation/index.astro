---
import Base from "../../layouts/Base.astro";
import SplitPortalHero from "../../components/SplitPortalHero.astro";
import WebPostsSection from "../../components/WebPostsSection.astro";
import LatestNewsSection from "../../components/LatestNewsSection.astro";
import { getWebPostSection } from "../../lib/ninetone";

let webPosts = await getWebPostSection("Ninetone Nation").catch(() => null);
---

<Base title="Ninetone Nation" theme="nation">
  <SplitPortalHero
    theme="nation"
    kicker="Ninetone Nation"
    left={{
      href: "/ninetone-nation/booking",
      label: "Entertainers",
      blurb: "Sweden's leading artists, hosts, and speakers — available for your event.",
      bgImage: "/images/nationBannerSection.png",
    }}
    right={{
      href: "/team",
      label: "The team",
      blurb: "The booking desk — the people handling every detail behind the scenes.",
      bgImage: "/images/meetTheTeamBanner.png",
    }}
  />
  <WebPostsSection data={webPosts} />
  <LatestNewsSection />
</Base>
