---
import Base from "../../layouts/Base.astro";
import ArtistCard from "../../components/ArtistCard.astro";
import SectionIntro from "../../components/SectionIntro.astro";
import { getBookingCategories, getWebPostSection } from "../../lib/ninetone";

let categories: Awaited<ReturnType<typeof getBookingCategories>> = [];
let fetchError: string | null = null;
try {
  categories = await getBookingCategories();
} catch (e) {
  fetchError = (e as Error).message;
}

// Section intro copy: pull from WebPosts (same as before).
const webPosts = await getWebPostSection("Ninetone Nation").catch(() => null);
const introBody =
  webPosts?.blocks?.find((b) => b.message)?.message ?? "";

const totalArtists = categories.reduce((n, c) => n + c.artists.length, 0);

// Slugify category names for in-page anchors (and stable element ids)
function slugifyTag(s: string): string {
  return s
    .toLowerCase()
    .normalize("NFD")
    .replace(/[̀-ͯ]/g, "")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-|-$/g, "");
}
---

<Base title="Booking" theme="nation">
  <SectionIntro
    title="Entertainers"
    tagline={webPosts?.title}
    readMore={introBody}
    theme="nation"
    logo="/images/nationLogo.png"
    logoAlt="Ninetone Nation"
  />

  <section class="bg-ninetone-paper pb-24">
    <div class="mx-auto max-w-7xl px-6">
      {fetchError && (
        <p class="border-l-2 border-ninetone-green bg-ninetone-paper-warm p-4 text-sm text-ninetone-ink/80">
          Couldn't load booking categories yet — set FM_USER / FM_PASS in .env to enable. ({fetchError})
        </p>
      )}

      {categories.length > 1 && (
        <nav
          class="mb-12 -mx-6 overflow-x-auto border-b border-ninetone-rule [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
          aria-label="Jump to category"
        >
          <ul class="flex items-center gap-1 px-6 pb-3">
            <li class="shrink-0">
              <span class="kicker text-ninetone-green">{totalArtists} bookable</span>
            </li>
            <li class="mx-3 h-4 w-px shrink-0 bg-ninetone-rule" aria-hidden></li>
            {categories.map((c) => (
              <li class="shrink-0">
                <a
                  href={`#cat-${slugifyTag(c.tag)}`}
                  class="inline-flex items-center gap-2 px-3 py-1.5 font-mono text-[0.6875rem] font-bold uppercase tracking-[0.12em] text-ninetone-ink/60 transition-colors hover:text-ninetone-ink"
                >
                  {c.tag}
                  <span class="text-ninetone-ink/35">{c.artists.length}</span>
                </a>
              </li>
            ))}
          </ul>
        </nav>
      )}

      <div class="space-y-24">
        {categories.map((c) => {
          const id = `cat-${slugifyTag(c.tag)}`;
          return (
            <section id={id} class="scroll-mt-28">
              <header class="mb-10 grid gap-6 md:grid-cols-12 md:gap-16">
                <div class="md:col-span-7">
                  <span class="kicker text-ninetone-green">
                    {c.tag} · {c.artists.length} {c.artists.length === 1 ? "talent" : "talents"}
                  </span>
                  <h2 class="mt-4 font-display text-[clamp(2rem,5vw,4rem)] leading-[0.95] tracking-[-0.035em]">
                    {c.tag === "Föreläsare" ? "Föreläsare." :
                     c.tag === "Konferencier" ? "Konferenciers." :
                     c.tag === "Moderator" ? "Moderatorer." :
                     c.tag === "Underhållare" ? "Underhållare." :
                     c.tag === "Influencer" ? "Influencers." :
                     `${c.tag}er.`}
                  </h2>
                </div>
                {c.description && (
                  <p class="md:col-span-5 md:pt-2 text-base leading-relaxed text-ninetone-ink/70">
                    {c.description}
                  </p>
                )}
              </header>

              <div class={`mt-2 h-px w-full bg-ninetone-green opacity-80`} aria-hidden></div>

              {c.artists.length === 0 ? (
                <p class="mt-10 text-sm text-ninetone-ink/55">No talents in this category yet.</p>
              ) : (
                <div class="mt-10 grid grid-cols-2 gap-x-6 gap-y-12 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5">
                  {c.artists.map((a) => (
                    <ArtistCard
                      theme="nation"
                      name={a.name}
                      slug={a.slug}
                      blurb={a.blurb}
                      image={a.imageSmall ?? a.imageBig}
                      tags={[c.tag]}
                      ctaLabel="Book"
                      kicker={a.highlight ? "Featured" : undefined}
                      socials={a.socials}
                    />
                  ))}
                </div>
              )}
            </section>
          );
        })}
      </div>
    </div>
  </section>
</Base>
