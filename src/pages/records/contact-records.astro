---
import Base from "../../layouts/Base.astro";
import ContactForm from "../../components/ContactForm.astro";
---

<Base title="Submit a demo" theme="records">
  <ContactForm
    theme="records"
    kicker="Records — Demos"
    heading="We listen to everything."
    tagline="Send the music. We reply with merit."
    blurb="Tell us who you are and where to hear it. Drop SoundCloud, Spotify, or direct download links — no file uploads, please."
    metrics={[
      { value: "31", label: "Active artists" },
      { value: "342", label: "Alumni" },
      { value: "16", label: "Years in the room" },
      { value: "5", label: "Studios" },
    ]}
    formTitle="We want your music."
    formBlurb="Paste links to your tracks. We listen weekly and reply within one business day."
    submitLabel="Submit demo"
    fields={[
      { type: "text", name: "name", label: "Name", placeholder: "Your name", required: true },
      { type: "email", name: "email", label: "Email", placeholder: "you@email.com", required: true },
      { type: "textarea", name: "links", label: "Links to your music", placeholder: "Spotify, SoundCloud, direct links… one per line", rows: 4, required: true },
      { type: "textarea", name: "about", label: "About you", placeholder: "A few lines on who you are, where you're based, what you're working on", rows: 4 },
    ]}
  />
</Base>
