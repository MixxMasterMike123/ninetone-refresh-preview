---
import Base from "../../../layouts/Base.astro";
import StreamingRow from "../../../components/StreamingRow.astro";
import MerchCard from "../../../components/MerchCard.astro";
import NewsCard from "../../../components/NewsCard.astro";
import RosterStrip from "../../../components/RosterStrip.astro";
import Discography from "../../../components/Discography.astro";
import { getArtists, getArtistDetailWithReleases, getNewsForArtist, pickRelatedArtists } from "../../../lib/ninetone";
import { getProducts } from "../../../lib/shopify";
import { renderBio } from "../../../lib/markdown";
import { url } from "../../../lib/url";

export async function getStaticPaths() {
  const artists = await getArtists();
  return artists.map((a) => ({
    params: { slug: String(a.SLUG ?? "") },
    props: { artist: a, allArtists: artists },
  }));
}

// Static build (gh): artist arrives via getStaticPaths props.
// Live server (cf): resolve at request time from the cached roster.
let { artist, allArtists } = Astro.props as {
  artist?: Record<string, unknown>;
  allArtists?: Record<string, unknown>[];
};
if (!artist || !allArtists) {
  allArtists = await getArtists();
  artist = allArtists.find((a) => String(a.SLUG ?? "") === Astro.params.slug);
  if (!artist) return Astro.rewrite("/404");
}
const slug = String(artist.SLUG ?? "");

// Discography is core page content — a failed fetch fails the render (the
// data layer serves last-known-good on transient errors; see lib/cache.ts).
const detail = await getArtistDetailWithReleases(slug);
const releases = detail?.releases ?? [];

const name = String(artist["Head Artist"] ?? "");
const tagline = String(artist["Artist Presentation Title"] ?? "");
const bioHtml = renderBio(String(artist.artistPresentationString ?? ""));
const heroImage = artist.artistPicture_big
  ? String(artist.artistPicture_big)
  : artist.artistPicture_small
  ? String(artist.artistPicture_small)
  : undefined;
const genres = artist.genre ? String(artist.genre).split(/\r|\n/).map((s) => s.trim()).filter(Boolean) : [];
const aandr = String(artist.internalAandR ?? "");
const aandrEmail = String(artist["Green_internalAandR::userEmail"] ?? "");
const ytOne = String(artist.yotubeHighlight_one ?? "");
const ytTwo = String(artist.yotubeHighlight_two ?? "");
const collectionId = String(artist.collectionId ?? "").trim();

const socials = {
  spotify: artist.url_spotify ? String(artist.url_spotify) : undefined,
  apple: artist.url_applemusic ? String(artist.url_applemusic) : undefined,
  amazon: artist.url_amazon ? String(artist.url_amazon) : undefined,
  youtubeMusic: artist.url_youtube_music ? String(artist.url_youtube_music) : undefined,
  youtube: artist.url_youtube_link ? String(artist.url_youtube_link) : undefined,
  instagram: artist.url_instagram ? String(artist.url_instagram) : undefined,
  tiktok: artist.url_tiktok_artist ? String(artist.url_tiktok_artist) : undefined,
  twitter: artist.url_twitter ? String(artist.url_twitter) : undefined,
  facebook: artist.url_facebook ? String(artist.url_facebook) : undefined,
  soundcloud: undefined,
};

const spotifyArtistMatch = String(artist.url_spotify_artist ?? "").match(/embed\/artist\/([a-zA-Z0-9]+)/);
const spotifyArtistId = spotifyArtistMatch ? spotifyArtistMatch[1] : null;

// News strip + merch are optional embellishments — log failures, don't fail
// the page over them.
let latestNews: Awaited<ReturnType<typeof getNewsForArtist>> = [];
try {
  latestNews = await getNewsForArtist(name, 4);
} catch (err) {
  console.error(`[artist:${slug}] news strip failed:`, err);
}

let merch: Awaited<ReturnType<typeof getProducts>> = [];
if (collectionId) {
  try {
    merch = await getProducts({ collectionId, limit: 8 });
  } catch (err) {
    console.error(`[artist:${slug}] merch fetch failed:`, err);
  }
}

// "In good company" — same-genre artists ranked by tag overlap, padded with
// random others if there aren't enough genre matches to fill the strip.
function recordsTagsOf(a: Record<string, unknown>): string[] {
  return a.genre ? String(a.genre).split(/\r|\n|,/).map((s) => s.trim()).filter(Boolean) : [];
}
const related = pickRelatedArtists(artist, allArtists, recordsTagsOf, 12);

const ytLinks = [ytOne, ytTwo].filter(Boolean);
---

<Base title={name} theme="records" description={tagline || `${name} | Ninetone Records`}>
  <!-- Cinematic split hero -->
  <section class="bg-ninetone-paper">
    <div class="mx-auto max-w-7xl px-6 pb-12 pt-12 md:pt-16">
      <p class="mb-8">
        <a href={url("/records/artists")} class="kicker text-ninetone-ink/55 hover:text-ninetone-ink">← Records · Artists</a>
      </p>

      <div class="grid gap-10 md:grid-cols-12 md:gap-16">
        <!-- Left: image (sticks on desktop) -->
        <aside class="md:col-span-5 lg:col-span-5">
          <div class="md:sticky md:top-24">
            <div class="fm-img-frame relative aspect-[4/5] w-full overflow-hidden bg-ninetone-paper-warm">
              {heroImage && (
                <img
                  src={heroImage}
                  alt={name}
                  class="fm-img h-full w-full object-cover"
                  onload="this.classList.add('is-loaded'); this.closest('.fm-img-frame')?.classList.add('is-ready')"
                />
              )}
              <span class="absolute left-0 top-0 h-1 w-16 bg-ninetone-red" aria-hidden></span>
            </div>

            <div class="mt-6 hidden md:block">
              <StreamingRow socials={socials} />
            </div>
          </div>
        </aside>

        <!-- Right: scrollable content -->
        <div class="md:col-span-7 lg:col-span-7">
          <span class="kicker text-ninetone-red">Records — Artist</span>
          <h1 class="mt-4 font-display text-[clamp(3rem,8vw,7rem)] leading-[0.9] tracking-[-0.045em]">{name}</h1>

          {tagline && (
            <p class="mt-6 max-w-xl font-display text-2xl italic leading-snug tracking-tight text-ninetone-ink/75 md:text-3xl">
              {tagline}
            </p>
          )}

          {genres.length > 0 && (
            <div class="mt-6 flex flex-wrap gap-x-4 gap-y-2 text-xs uppercase tracking-[0.16em] text-ninetone-ink/60">
              {genres.slice(0, 6).map((g, i) => (
                <span>{i > 0 && <span aria-hidden class="mr-4 opacity-40">·</span>}{g}</span>
              ))}
            </div>
          )}

          <!-- Mobile streaming row -->
          <div class="mt-8 md:hidden">
            <StreamingRow socials={socials} />
          </div>

          <!-- Bio -->
          <div class="mt-12 prose lede max-w-none" set:html={bioHtml}></div>

          <!-- YouTube highlights -->
          {ytLinks.length > 0 && (
            <div class="mt-16 border-t border-ninetone-rule pt-10">
              <span class="kicker text-ninetone-ink/55">Watch</span>
              <div class="mt-6 grid gap-4 sm:grid-cols-2">
                {ytLinks.map((url) => {
                  const idMatch = url.match(/(?:v=|youtu\.be\/|embed\/)([\w-]{11})/);
                  const id = idMatch ? idMatch[1] : null;
                  return id ? (
                    <iframe
                      src={`https://www.youtube.com/embed/${id}`}
                      class="aspect-video w-full"
                      title={`${name} video`}
                      loading="lazy"
                      allowfullscreen
                    ></iframe>
                  ) : null;
                })}
              </div>
            </div>
          )}

          <!-- Spotify embed -->
          {spotifyArtistId && (
            <div class="mt-16 border-t border-ninetone-rule pt-10">
              <span class="kicker text-ninetone-red">On Spotify</span>
              <div class="mt-6">
                <iframe
                  src={`https://open.spotify.com/embed/artist/${spotifyArtistId}?utm_source=generator&theme=0`}
                  width="100%"
                  height="352"
                  frameborder="0"
                  allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
                  loading="lazy"
                ></iframe>
              </div>
            </div>
          )}

          <!-- A&R / Inquiries -->
          {(aandr || aandrEmail) && (
            <div class="mt-16 border-t border-ninetone-rule pt-10">
              <span class="kicker text-ninetone-red">Represented by</span>
              <div class="mt-4 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
                <div>
                  <p class="font-display text-2xl font-medium leading-tight tracking-tight">{aandr || "Ninetone Records"}</p>
                  {aandrEmail && (
                    <a href={`mailto:${aandrEmail}`} class="mt-2 inline-block text-sm text-ninetone-ink/70 underline-offset-4 hover:underline">
                      {aandrEmail}
                    </a>
                  )}
                </div>
                <a
                  href={url("/records/contact-records")}
                  class="inline-flex items-center gap-2 self-start bg-ninetone-red px-4 py-3 text-sm font-semibold text-ninetone-paper transition-colors hover:bg-ninetone-red-dark"
                >
                  Get in touch <span aria-hidden>→</span>
                </a>
              </div>
            </div>
          )}

          <!-- News mentioning this artist -->
          {latestNews.length > 0 && (
            <div class="mt-16 border-t border-ninetone-rule pt-10">
              <span class="kicker text-ninetone-ink/55">In the news</span>
              <ul class="mt-6 grid gap-x-8 gap-y-10 md:grid-cols-2">
                {latestNews.map((p) => (
                  <li>
                    <NewsCard
                      title={String(p.Title ?? "")}
                      slug={String(p.slug ?? "")}
                      image={p.image_webp ? String(p.image_webp) : undefined}
                      date={String(p.Date ?? "")}
                      category={String(p.category ?? "")}
                      hasVideo={["ytLinkA","ytLinkB","ytLinkC","ytLinkD"].some((k) => typeof (p as Record<string, unknown>)[k] === "string" && ((p as Record<string, unknown>)[k] as string).trim().length > 0)}
                      size="sm"
                    />
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- Discography -->
  <Discography releases={releases} artistName={name} theme="records" />

  <!-- Merch -->
  {merch.length > 0 && (
    <section class="bg-ninetone-paper-warm py-20">
      <div class="mx-auto max-w-7xl px-6">
        <div class="mb-10 grid gap-4 md:grid-cols-[1fr_auto] md:items-end">
          <div>
            <span class="kicker text-ninetone-red">Merch</span>
            <h2 class="mt-3 font-display text-4xl leading-[1.05] tracking-tight md:text-5xl">{name} — official.</h2>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-x-6 gap-y-12 md:grid-cols-3 lg:grid-cols-4">
          {merch.map((p) => <MerchCard product={p} />)}
        </div>
      </div>
    </section>
  )}

  <!-- More from the roster -->
  {related.length > 0 && (
    <RosterStrip
      artists={related}
      theme="records"
      kicker="More from Records"
      heading="In good company."
      cta={{ label: "All artists", href: "/records/artists" }}
    />
  )}
</Base>
