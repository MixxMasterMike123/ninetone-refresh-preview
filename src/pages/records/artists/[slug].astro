---
import Base from "../../../layouts/Base.astro";
import SocialRow from "../../../components/SocialRow.astro";
import MerchCard from "../../../components/MerchCard.astro";
import NewsCard from "../../../components/NewsCard.astro";
import { getArtists, getNewsForArtist } from "../../../lib/ninetone";
import { getProducts } from "../../../lib/shopify";
import { renderBio } from "../../../lib/markdown";

export async function getStaticPaths() {
  const artists = await getArtists();
  return artists.map((a) => ({
    params: { slug: String(a.SLUG ?? "") },
    props: { artist: a },
  }));
}

const { artist } = Astro.props as { artist: Record<string, unknown> };

const name = String(artist["Head Artist"] ?? "");
// Records uses the `artistPresentation*` family of fields
const tagline = String(artist["Artist Presentation Title"] ?? "");
const bioHtml = renderBio(String(artist.artistPresentationString ?? ""));
const image = artist.artistPicture_small ? String(artist.artistPicture_small) : undefined;
const genres = artist.genre ? String(artist.genre).split(/\r|\n/).filter(Boolean) : [];
const aandr = String(artist.internalAandR ?? "");
const aandrEmail = String(artist["Green_internalAandR::userEmail"] ?? "");
const ytOne = String(artist.yotubeHighlight_one ?? "");
const ytTwo = String(artist.yotubeHighlight_two ?? "");
const collectionId = String(artist.collectionId ?? "").trim();

// Spotify embed: extract just the artist ID from the malformed iframe HTML
const spotifyArtistMatch = String(artist.url_spotify_artist ?? "").match(/embed\/artist\/([a-zA-Z0-9]+)/);
const spotifyArtistId = spotifyArtistMatch ? spotifyArtistMatch[1] : null;

// News mentioning this artist
let latestNews: Awaited<ReturnType<typeof getNewsForArtist>> = [];
try {
  latestNews = await getNewsForArtist(name, 3);
} catch {}

// Artist merch via Shopify collection_id
let merch: Awaited<ReturnType<typeof getProducts>> = [];
if (collectionId) {
  try {
    merch = await getProducts({ collectionId, limit: 8 });
  } catch {}
}
---

<Base title={name} theme="records" description={tagline || `${name} | Ninetone Records`}>
  <section class="relative overflow-hidden bg-ninetone-ink py-20 text-white">
    {image && (
      <div class="absolute inset-0 opacity-20" style={`background-image: url(${image}); background-size: cover; background-position: center;`}></div>
    )}
    <div class="relative mx-auto max-w-7xl px-6">
      <p class="mb-2 text-xs uppercase tracking-wider opacity-70">
        <a href="/records/artists" class="hover:underline">← Artists</a>
      </p>
      <h1 class="font-display text-5xl">{name}</h1>
      <SocialRow
        spotify={String(artist.url_spotify ?? "")}
        applemusic={String(artist.url_applemusic ?? "")}
        amazon={String(artist.url_amazon ?? "")}
        youtube={String(artist.url_youtube_music ?? "")}
        instagram={String(artist.url_instagram ?? "")}
        tiktok={String(artist.url_tiktok_artist ?? "")}
        facebook={String(artist.url_facebook ?? "")}
        twitter={String(artist.url_twitter ?? "")}
      />
    </div>
  </section>

  <section class="bg-white py-16">
    <div class="mx-auto grid max-w-7xl grid-cols-1 gap-12 px-6 lg:grid-cols-[1fr_320px]">
      <article class="prose max-w-none">
        {tagline && <h2 class="font-display text-3xl text-ninetone-ink">{tagline}</h2>}

        {genres.length > 0 && (
          <div class="not-prose mb-6 flex flex-wrap gap-2">
            {genres.map((g) => (
              <span class="rounded bg-ninetone-ink/10 px-3 py-1 text-xs uppercase tracking-wider text-ninetone-ink">{g}</span>
            ))}
          </div>
        )}

        {image && (
          <img src={image} alt={name} class="not-prose mb-8 w-full rounded-sm object-cover" />
        )}

        <div class="prose max-w-none text-neutral-800" set:html={bioHtml}></div>

        {(ytOne || ytTwo) && (
          <div class="not-prose mt-12 grid gap-4 sm:grid-cols-2">
            {[ytOne, ytTwo].filter(Boolean).map((url) => {
              const idMatch = url.match(/(?:v=|youtu\.be\/|embed\/)([\w-]{11})/);
              const id = idMatch ? idMatch[1] : null;
              return id ? (
                <iframe
                  src={`https://www.youtube.com/embed/${id}`}
                  class="aspect-video w-full rounded"
                  title={`${name} video`}
                  loading="lazy"
                  allowfullscreen
                ></iframe>
              ) : null;
            })}
          </div>
        )}
      </article>

      <aside class="flex flex-col gap-6">
        <div class="rounded bg-ninetone-navy p-5 text-white">
          <h3 class="font-display text-lg">Inquiries</h3>
          {aandr && (
            <p class="mt-2 text-sm">
              A&amp;R: {aandrEmail ? <a href={`mailto:${aandrEmail}`} class="underline">{aandr}</a> : aandr}
            </p>
          )}
          <p class="mt-3 text-xs opacity-90">
            For inquiries about {name}, contact the A&amp;R Manager for personalized assistance, or use our contact form.
          </p>
          <a href="/records/contact-records" class="mt-4 inline-flex items-center gap-2 rounded-sm bg-white px-3 py-1.5 text-xs font-semibold text-ninetone-navy">
            Contact <span aria-hidden>→</span>
          </a>
        </div>

        {spotifyArtistId && (
          <div>
            <h3 class="mb-2 font-display text-lg">Latest release</h3>
            <iframe
              src={`https://open.spotify.com/embed/artist/${spotifyArtistId}?utm_source=generator`}
              width="100%"
              height="352"
              frameborder="0"
              allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
              loading="lazy"
              class="rounded"
            ></iframe>
          </div>
        )}

        {latestNews.length > 0 && (
          <div>
            <h3 class="mb-2 font-display text-lg">Latest news</h3>
            <div class="grid gap-3">
              {latestNews.map((p) => (
                <NewsCard
                  title={String(p.Title ?? "")}
                  slug={String(p.slug ?? "")}
                  image={p.image_webp ? String(p.image_webp) : undefined}
                  excerpt={String(p.shortMessage ?? "").slice(0, 80)}
                  date={String(p.Date ?? "")}
                />
              ))}
            </div>
          </div>
        )}
      </aside>
    </div>
  </section>

  {merch.length > 0 && (
    <section class="bg-ninetone-ink py-16">
      <div class="mx-auto max-w-7xl px-6">
        <h2 class="font-display text-2xl uppercase tracking-wider text-white">{name} Merch</h2>
        <div class="mt-8 grid grid-cols-2 gap-4 md:grid-cols-3 lg:grid-cols-4">
          {merch.map((p) => <MerchCard product={p} />)}
        </div>
      </div>
    </section>
  )}
</Base>
