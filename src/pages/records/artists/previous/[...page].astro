---
import Base from "../../../../layouts/Base.astro";
import ArtistCard from "../../../../components/ArtistCard.astro";
import ArtistsTabs from "../../../../components/ArtistsTabs.astro";
import Pagination from "../../../../components/Pagination.astro";
import SectionIntro from "../../../../components/SectionIntro.astro";
import { getArtists, getPreviousArtists, getWebPostSection } from "../../../../lib/ninetone";

// Exported so the hoisted getStaticPaths and the request-time path below
// share one definition (only exports are hoisted to module scope in Astro).
export const PAGE_SIZE = 30;

export async function getStaticPaths({ paginate }: { paginate: any }) {
  const artists = await getPreviousArtists();
  return paginate(artists, { pageSize: PAGE_SIZE });
}

type PageShape = {
  data: Awaited<ReturnType<typeof getPreviousArtists>>;
  currentPage: number;
  lastPage: number;
  total: number;
};

// Static build (gh): `page` arrives from paginate() via getStaticPaths.
// Live server (cf): paginate() never runs — slice the cached list by the
// route param ("" = page 1, "2", "3", …) at request time.
let page = (Astro.props as { page?: PageShape }).page;
if (!page) {
  const raw = String((Astro.params as { page?: string }).page ?? "");
  if (raw !== "" && !/^\d+$/.test(raw)) return Astro.rewrite("/404");
  const currentPage = raw === "" ? 1 : parseInt(raw, 10);
  const all = await getPreviousArtists();
  const lastPage = Math.max(1, Math.ceil(all.length / PAGE_SIZE));
  if (currentPage < 1 || currentPage > lastPage) return Astro.rewrite("/404");
  page = {
    data: all.slice((currentPage - 1) * PAGE_SIZE, currentPage * PAGE_SIZE),
    currentPage,
    lastPage,
    total: all.length,
  };
}

// Reuse Records section intro. Both fetches cached, so effectively free.
const active = await getArtists();
const introBody = String((active[0] as Record<string, unknown> | undefined)?.readMore ?? "");
const webPosts = await getWebPostSection("Ninetone Records");
---

<Base title="Previous Artists" theme="records">
  <SectionIntro
    title="Previous Artists"
    tagline={webPosts?.title}
    readMore={introBody}
    theme="records"
    logo="/images/recordsLogo.png"
    logoAlt="Ninetone Records"
  />
  <section class="bg-ninetone-paper pt-2">
    <div class="mx-auto max-w-7xl px-6">
      <p class="text-xs uppercase tracking-[0.16em] text-ninetone-ink/55">
        Showing {(page.currentPage - 1) * 30 + 1}–{Math.min(page.currentPage * 30, page.total)} of {page.total}
      </p>
    </div>
  </section>

  <section class="bg-ninetone-paper pb-20">
    <div class="mx-auto max-w-7xl px-6">
      <ArtistsTabs active="previous" />

      <div class="grid grid-cols-2 gap-x-6 gap-y-12 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5">
        {page.data.map((a) => (
          <ArtistCard
            theme="records"
            href={`/records/artists/previous/single/${String(a.SLUG ?? "")}`}
            name={String(a["Head Artist"] ?? "")}
            slug={String(a.SLUG ?? "")}
            blurb={String(a.artistPresentationShort ?? "")}
            image={a.artistPicture_small ? String(a.artistPicture_small) : undefined}
            tags={a.genre ? String(a.genre).split(/\r|\n/).filter(Boolean) : []}
            socials={{
              spotify: a.url_spotify ? String(a.url_spotify) : undefined,
              apple: a.url_applemusic ? String(a.url_applemusic) : undefined,
              instagram: a.url_instagram ? String(a.url_instagram) : undefined,
            }}
          />
        ))}
      </div>

      <Pagination
        currentPage={page.currentPage}
        lastPage={page.lastPage}
        baseUrl="/records/artists/previous"
      />
    </div>
  </section>
</Base>
