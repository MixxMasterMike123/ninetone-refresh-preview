---
import Base from "../../../../../layouts/Base.astro";
import StreamingRow from "../../../../../components/StreamingRow.astro";
import MerchCard from "../../../../../components/MerchCard.astro";
import NewsCard from "../../../../../components/NewsCard.astro";
import { getPreviousArtists, getNewsForArtist } from "../../../../../lib/ninetone";
import { getProducts } from "../../../../../lib/shopify";
import { renderBio } from "../../../../../lib/markdown";

export async function getStaticPaths() {
  const artists = await getPreviousArtists();
  return artists
    .filter((a) => a.SLUG)
    .map((a) => ({
      params: { slug: String(a.SLUG) },
      props: { artist: a },
    }));
}

const { artist } = Astro.props as { artist: Record<string, unknown> };

const name = String(artist["Head Artist"] ?? "");
const tagline = String(artist["Artist Presentation Title"] ?? "");
const bioHtml = renderBio(String(artist.artistPresentationString ?? ""));
const heroImage = artist.artistPicture_big
  ? String(artist.artistPicture_big)
  : artist.artistPicture_small
  ? String(artist.artistPicture_small)
  : undefined;
const tags = artist.genre ? String(artist.genre).split(/\r|\n/).map((s) => s.trim()).filter(Boolean) : [];
const collectionId = String(artist.collectionId ?? "").trim();

const socials = {
  spotify: artist.url_spotify ? String(artist.url_spotify) : undefined,
  apple: artist.url_applemusic ? String(artist.url_applemusic) : undefined,
  amazon: artist.url_amazon ? String(artist.url_amazon) : undefined,
  youtubeMusic: artist.url_youtube_music ? String(artist.url_youtube_music) : undefined,
  youtube: artist.url_youtube_link ? String(artist.url_youtube_link) : undefined,
  instagram: artist.url_instagram ? String(artist.url_instagram) : undefined,
  tiktok: artist.url_tiktok_artist ? String(artist.url_tiktok_artist) : undefined,
  twitter: artist.url_twitter ? String(artist.url_twitter) : undefined,
  facebook: artist.url_facebook ? String(artist.url_facebook) : undefined,
  soundcloud: undefined,
};

let merch: Awaited<ReturnType<typeof getProducts>> = [];
if (collectionId) {
  try { merch = await getProducts({ collectionId, limit: 8 }); } catch {}
}

let latestNews: Awaited<ReturnType<typeof getNewsForArtist>> = [];
try { latestNews = await getNewsForArtist(name, 3); } catch {}

const ytLinks = [String(artist.yotubeHighlight_one ?? ""), String(artist.yotubeHighlight_two ?? "")].filter(Boolean);
---

<Base title={name} theme="records" description={tagline || `${name} | Previous Artists | Ninetone`}>
  <section class="bg-ninetone-paper">
    <div class="mx-auto max-w-7xl px-6 pb-12 pt-12 md:pt-16">
      <p class="mb-8">
        <a href="/records/artists/previous" class="kicker text-ninetone-ink/55 hover:text-ninetone-ink">← Records · Previous artists</a>
      </p>

      <div class="grid gap-10 md:grid-cols-12 md:gap-16">
        <aside class="md:col-span-5 lg:col-span-5">
          <div class="md:sticky md:top-24">
            <div class="relative aspect-[4/5] w-full overflow-hidden bg-ninetone-paper-warm">
              {heroImage && <img src={heroImage} alt={name} class="h-full w-full object-cover" />}
              <span class="absolute left-0 top-0 h-1 w-16 bg-ninetone-red opacity-70" aria-hidden></span>
            </div>
            <div class="mt-6 hidden md:block">
              <StreamingRow socials={socials} />
            </div>
          </div>
        </aside>

        <div class="md:col-span-7 lg:col-span-7">
          <span class="kicker text-ninetone-red">Records — Archive</span>
          <h1 class="mt-4 font-display text-[clamp(3rem,8vw,7rem)] leading-[0.9] tracking-[-0.045em]">{name}</h1>

          {tagline && (
            <p class="mt-6 max-w-xl font-display text-2xl italic leading-snug tracking-tight text-ninetone-ink/75 md:text-3xl">
              {tagline}
            </p>
          )}

          {tags.length > 0 && (
            <div class="mt-6 flex flex-wrap gap-x-4 gap-y-2 text-xs uppercase tracking-[0.16em] text-ninetone-ink/60">
              {tags.slice(0, 6).map((g, i) => (
                <span>{i > 0 && <span aria-hidden class="mr-4 opacity-40">·</span>}{g}</span>
              ))}
            </div>
          )}

          <div class="mt-8 md:hidden">
            <StreamingRow socials={socials} />
          </div>

          {bioHtml && <div class="mt-12 prose lede max-w-none" set:html={bioHtml}></div>}

          {ytLinks.length > 0 && (
            <div class="mt-16 border-t border-ninetone-rule pt-10">
              <span class="kicker text-ninetone-ink/55">Watch</span>
              <div class="mt-6 grid gap-4 sm:grid-cols-2">
                {ytLinks.map((url) => {
                  const idMatch = url.match(/(?:v=|youtu\.be\/|embed\/)([\w-]{11})/);
                  const id = idMatch ? idMatch[1] : null;
                  return id ? (
                    <iframe src={`https://www.youtube.com/embed/${id}`} class="aspect-video w-full" title={`${name} video`} loading="lazy" allowfullscreen></iframe>
                  ) : null;
                })}
              </div>
            </div>
          )}

          {latestNews.length > 0 && (
            <div class="mt-16 border-t border-ninetone-rule pt-10">
              <span class="kicker text-ninetone-ink/55">In the news</span>
              <ul class="mt-6 grid gap-x-8 gap-y-10 md:grid-cols-2">
                {latestNews.map((p) => (
                  <li>
                    <NewsCard
                      title={String(p.Title ?? "")}
                      slug={String(p.slug ?? "")}
                      image={p.image_webp ? String(p.image_webp) : undefined}
                      date={String(p.Date ?? "")}
                      category={String(p.category ?? "")}
                      size="sm"
                    />
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  {merch.length > 0 && (
    <section class="bg-ninetone-paper-warm py-20">
      <div class="mx-auto max-w-7xl px-6">
        <div class="mb-10">
          <span class="kicker text-ninetone-red">Merch</span>
          <h2 class="mt-3 font-display text-4xl leading-[1.05] tracking-tight md:text-5xl">{name} — official.</h2>
        </div>
        <div class="grid grid-cols-2 gap-x-6 gap-y-12 md:grid-cols-3 lg:grid-cols-4">
          {merch.map((p) => <MerchCard product={p} />)}
        </div>
      </div>
    </section>
  )}
</Base>
