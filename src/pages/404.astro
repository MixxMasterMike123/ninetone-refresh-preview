---
import Base from "../layouts/Base.astro";
---

<Base title="Page not found" theme="group">
  <section class="bg-ninetone-ink py-24 text-white">
    <div class="mx-auto max-w-2xl px-6 text-center">
      <p class="font-display text-7xl font-bold tracking-tight text-ninetone-red">404</p>
      <h1 class="mt-6 font-display text-4xl">This page took a different gig.</h1>
      <p class="mt-4 text-white/80">
        The page you're looking for isn't here. It may have moved, been renamed, or never existed.
      </p>
      <div class="mt-10 flex flex-wrap justify-center gap-3">
        <a
          href="/"
          class="inline-flex min-h-11 items-center gap-2 rounded-md bg-white px-5 py-2 text-sm font-semibold text-ninetone-ink hover:bg-neutral-100"
        >
          Back to home <span aria-hidden>→</span>
        </a>
        <a
          href="/search-result"
          class="inline-flex min-h-11 items-center gap-2 rounded-md bg-white/10 px-5 py-2 text-sm font-semibold text-white hover:bg-white/20"
        >
          Search the site
        </a>
      </div>
      <div class="mt-12 grid grid-cols-1 gap-3 text-left sm:grid-cols-3">
        <a href="/records" class="rounded-md bg-ninetone-red/20 p-4 hover:bg-ninetone-red/30">
          <p class="text-xs uppercase tracking-wider text-white/60">Records</p>
          <p class="mt-1 font-semibold">Artists & releases</p>
        </a>
        <a href="/management" class="rounded-md bg-ninetone-navy/30 p-4 hover:bg-ninetone-navy/40">
          <p class="text-xs uppercase tracking-wider text-white/60">Management</p>
          <p class="mt-1 font-semibold">Talent & clients</p>
        </a>
        <a href="/ninetone-nation" class="rounded-md bg-ninetone-green/20 p-4 hover:bg-ninetone-green/30">
          <p class="text-xs uppercase tracking-wider text-white/60">Nation</p>
          <p class="mt-1 font-semibold">Booking & events</p>
        </a>
      </div>
    </div>
  </section>
</Base>
