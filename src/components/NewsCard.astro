---
import { url } from "../lib/url";

interface Props {
  title: string;
  slug: string;
  image?: string;
  excerpt?: string;
  date?: string;
  author?: string;
  category?: string;
  lang?: "en" | "sv";
  /** Visual scale — sm/md/lg drive type sizes for grid hierarchy. */
  size?: "sm" | "md" | "lg";
  /** Article includes one or more embedded YouTube videos (ytLinkA-D). */
  hasVideo?: boolean;
}

const { title, slug, image, excerpt, date, author, category, lang = "en", size = "md", hasVideo = false } = Astro.props;
const readMore = lang === "sv" ? "Läs" : "Read";
const href = url(`/news/${slug}`);

const titleClass = size === "lg"
  ? "font-display text-3xl font-medium leading-[1.1] tracking-tight md:text-5xl"
  : size === "sm"
  ? "font-display text-lg font-medium leading-tight tracking-tight"
  : "font-display text-2xl font-medium leading-tight tracking-tight";

const aspectClass = size === "lg" ? "aspect-[16/9]" : "aspect-[16/10]";
---

<article class="group flex flex-col">
  <a href={href} class={`fm-img-frame relative block ${aspectClass} overflow-hidden bg-ninetone-ink/5`}>
    {image && (
      <img
        src={image}
        alt={title}
        class="fm-img h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.04]"
        loading="lazy"
        onload="this.classList.add('is-loaded'); this.closest('.fm-img-frame')?.classList.add('is-ready')"
      />
    )}
    <span class="absolute left-0 top-0 h-1 w-12 bg-ninetone-red transition-[width] duration-300 ease-out group-hover:w-full" aria-hidden></span>
    {hasVideo && (
      <span
        class="absolute bottom-3 right-3 inline-flex h-9 w-9 items-center justify-center bg-ninetone-paper/95 text-ninetone-ink shadow-[0_1px_0_rgba(0,0,0,0.04)] backdrop-blur-sm"
        aria-label={lang === "sv" ? "Innehåller video" : "Contains video"}
        title={lang === "sv" ? "Innehåller video" : "Contains video"}
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-3.5 w-3.5" aria-hidden="true">
          <path d="M8 5v14l11-7z"></path>
        </svg>
      </span>
    )}
  </a>

  <div class="flex flex-1 flex-col gap-3 pt-4">
    {(category || date) && (
      <div class="flex items-center gap-3 text-[0.6875rem] uppercase tracking-[0.16em] text-ninetone-ink/55">
        {category && <span>{category}</span>}
        {category && date && <span class="opacity-40">·</span>}
        {date && <time>{date}</time>}
      </div>
    )}

    <h3 class={titleClass}>
      <a href={href} class="transition-colors hover:opacity-70">{title}</a>
    </h3>

    {excerpt && (
      <p class="text-[0.9375rem] leading-relaxed text-ninetone-ink/70 line-clamp-3">{excerpt}</p>
    )}

    {author && (
      <p class="text-xs uppercase tracking-[0.12em] text-ninetone-ink/55">{lang === "sv" ? "Av" : "By"} {author}</p>
    )}

    <a
      href={href}
      class="mt-auto inline-flex items-center gap-2 pt-2 text-xs font-semibold uppercase tracking-[0.16em] text-ninetone-ink"
    >
      {readMore} <span aria-hidden>→</span>
    </a>
  </div>
</article>
