---
import type { SectionTheme } from "../lib/sections";
import { sectionAccent } from "../lib/sections";
import { url } from "../lib/url";

export interface ContactField {
  type: "text" | "email" | "tel" | "textarea";
  name: string;
  label: string;
  placeholder?: string;
  required?: boolean;
  /** For textarea only — visible row count. */
  rows?: number;
  /** For input fields — 1 spans full width, omit for half-width. */
  cols?: 1 | 2;
}

interface Props {
  /** Theme drives accent color (button + rule). */
  theme?: SectionTheme;
  /** Kicker label above the headline. */
  kicker: string;
  /** Big editorial headline. */
  heading: string;
  /** Optional italic display tagline shown under the heading. */
  tagline?: string;
  /** Lede paragraph. */
  blurb: string;
  /** Optional metric tiles rendered in the left column. */
  metrics?: Array<{ value: string; label: string }>;
  /** Form-side micro headline. */
  formTitle: string;
  /** Form-side description. */
  formBlurb?: string;
  /** Field config — drives the form layout. */
  fields: ContactField[];
  /** Submit button label. */
  submitLabel: string;
  /** POST endpoint. Defaults to a stub. */
  action?: string;
}

const {
  theme = "group",
  kicker,
  heading,
  tagline,
  blurb,
  metrics = [],
  formTitle,
  formBlurb,
  fields,
  submitLabel,
  action: actionProp = "/api/contact",
} = Astro.props as Props;

const action = url(actionProp);

const accent = sectionAccent[theme];
---

<section class="bg-ninetone-paper">
  <div class="mx-auto max-w-7xl px-6 pb-16 pt-12 md:pb-24 md:pt-20">
    <div class="grid gap-12 md:grid-cols-12 md:gap-16">
      <!-- Left: editorial intro + metrics -->
      <div class="md:col-span-6">
        <span class={`kicker ${accent.text}`}>{kicker}</span>
        <h1 class="mt-6 font-display text-[clamp(2.5rem,6vw,5rem)] leading-[0.95] tracking-[-0.035em]">
          {heading}
        </h1>
        {tagline && (
          <p class="mt-6 max-w-xl font-display text-2xl italic leading-snug tracking-tight text-ninetone-ink/75 md:text-3xl">
            {tagline}
          </p>
        )}
        <p class="mt-6 max-w-xl text-base leading-relaxed text-ninetone-ink/70 md:text-lg">{blurb}</p>

        {metrics.length > 0 && (
          <dl class="mt-12 grid gap-x-6 gap-y-8 sm:grid-cols-2 md:grid-cols-4">
            {metrics.map((m) => (
              <div>
                <span class={`block h-px w-10 ${accent.bg}`} aria-hidden></span>
                <dd class="mt-3 font-display text-4xl font-medium leading-none tracking-[-0.02em]">{m.value}</dd>
                <dt class="mt-2 font-mono text-[0.625rem] uppercase tracking-[0.12em] text-ninetone-ink/55">{m.label}</dt>
              </div>
            ))}
          </dl>
        )}
      </div>

      <!-- Right: form card -->
      <div class="md:col-span-6">
        <div class="border border-ninetone-rule bg-ninetone-paper-warm p-6 md:p-8">
          <span class={`kicker ${accent.text}`}>{accent.label}</span>
          <h2 class="mt-3 font-display text-3xl leading-tight tracking-tight md:text-4xl">{formTitle}</h2>
          {formBlurb && (
            <p class="mt-3 text-sm text-ninetone-ink/65">{formBlurb}</p>
          )}

          <form
            class="mt-8 grid gap-5"
            method="post"
            action={action}
            data-contact-form
            data-theme={theme}
          >
            {fields.map((f) => {
              if (f.type === "textarea") {
                return (
                  <label class="grid gap-1.5">
                    <span class="font-mono text-[0.625rem] uppercase tracking-[0.16em] text-ninetone-ink/65">
                      {f.label}{f.required && <span class={`ml-1 ${accent.text}`}>*</span>}
                    </span>
                    <textarea
                      name={f.name}
                      rows={f.rows ?? 4}
                      placeholder={f.placeholder}
                      required={f.required}
                      class="w-full border border-ninetone-ink/15 bg-ninetone-paper px-3 py-2.5 text-sm text-ninetone-ink placeholder-ninetone-ink/35 focus:border-ninetone-ink focus:outline-none"
                    ></textarea>
                  </label>
                );
              }
              const colSpan = f.cols === 1 ? "sm:col-span-2" : "";
              return (
                <label class={`grid gap-1.5 ${colSpan}`}>
                  <span class="font-mono text-[0.625rem] uppercase tracking-[0.16em] text-ninetone-ink/65">
                    {f.label}{f.required && <span class={`ml-1 ${accent.text}`}>*</span>}
                  </span>
                  <input
                    type={f.type}
                    name={f.name}
                    placeholder={f.placeholder}
                    required={f.required}
                    class="w-full border border-ninetone-ink/15 bg-ninetone-paper px-3 py-2.5 text-sm text-ninetone-ink placeholder-ninetone-ink/35 focus:border-ninetone-ink focus:outline-none"
                  />
                </label>
              );
            })}

            <p class="mt-4 text-[0.6875rem] leading-relaxed text-ninetone-ink/55">
              Genom att skicka in samtycker du till att Ninetone Group AB behandlar dina uppgifter för att besvara din förfrågan. Läs vår <a href="/integritet" class="underline underline-offset-2 hover:text-ninetone-ink">integritetspolicy</a>.
            </p>

            <div class="mt-3 flex items-center justify-between gap-3">
              <p class="text-[0.6875rem] text-ninetone-ink/50">
                We reply within one business day.
              </p>
              <button
                type="submit"
                class={`inline-flex items-center gap-2 px-5 py-3 text-sm font-semibold ${accent.cta} transition-colors`}
              >
                {submitLabel} <span aria-hidden>→</span>
              </button>
            </div>

            <p data-form-status class="hidden text-sm"></p>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Optimistic-UX submit (stub — wire to real handler once endpoint exists).
  document.querySelectorAll<HTMLFormElement>("form[data-contact-form]").forEach((form) => {
    form.addEventListener("submit", async (e) => {
      const status = form.querySelector<HTMLElement>("[data-form-status]");
      const button = form.querySelector<HTMLButtonElement>("button[type=submit]");
      if (!status || !button) return;

      e.preventDefault();
      const original = button.textContent;
      button.textContent = "Sending…";
      button.disabled = true;
      status.classList.remove("hidden");
      status.textContent = "";

      try {
        const data = new FormData(form);
        const res = await fetch(form.action, {
          method: "POST",
          body: data,
        });
        if (res.ok) {
          form.reset();
          status.textContent = "Thanks — we'll be in touch.";
          status.className = "text-sm text-ninetone-ink";
          button.textContent = "Sent ✓";
        } else {
          status.textContent = "Something went wrong. Please try again or email us.";
          status.className = "text-sm text-ninetone-red";
          button.disabled = false;
          button.textContent = original;
        }
      } catch {
        status.textContent = "Network error. Please try again.";
        status.className = "text-sm text-ninetone-red";
        button.disabled = false;
        button.textContent = original;
      }
    });
  });
</script>
