---
/**
 * Discography — vertical stack of releases on an artist detail page.
 *
 * Each release is one editorial row: square cover left, copy + streaming
 * right. Mobile collapses to a single column. Newest first.
 *
 * Source: ArtistRelease[] from getArtistDetailWithReleases() in
 * src/lib/ninetone.ts. Cover URLs already point at the FM image proxy.
 */
import type { ArtistRelease } from "../lib/ninetone";
import type { SectionTheme } from "../lib/sections";
import { sectionAccent } from "../lib/sections";

interface Props {
  releases: ArtistRelease[];
  artistName: string;
  theme?: SectionTheme;
}

const { releases, artistName, theme = "records" } = Astro.props;
const accent = sectionAccent[theme];

function formatDate(fm: string): string {
  // FM stores MM/DD/YYYY. Render as "27 Jun 2025" — typographically calmer.
  const m = fm.match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})$/);
  if (!m) return fm;
  const months = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
  return `${Number(m[2])} ${months[Number(m[1]) - 1]} ${m[3]}`;
}

// Streaming icon glyphs match StreamingRow's vocabulary.
const PLATFORMS: Array<{ key: keyof ArtistRelease["streaming"]; label: string; glyph: string }> = [
  { key: "spotify", label: "Spotify", glyph: "S" },
  { key: "apple", label: "Apple Music", glyph: "" },
  { key: "youtubeMusic", label: "YouTube Music", glyph: "▶" },
  { key: "amazon", label: "Amazon Music", glyph: "Az" },
  { key: "tidal", label: "Tidal", glyph: "Td" },
];
---

{releases.length > 0 && (
  <section class="border-t border-ninetone-rule bg-ninetone-paper py-20 md:py-28">
    <div class="mx-auto max-w-7xl px-6">
      <header class="mb-14 grid gap-4 md:grid-cols-12 md:items-end">
        <div class="md:col-span-7">
          <span class={`kicker ${accent.text}`}>Records · Discography</span>
          <h2 class="mt-3 font-display text-4xl leading-[1.05] tracking-tight md:text-6xl">
            {releases.length === 1 ? "A release." : "Releases."}
          </h2>
        </div>
        <p class="text-sm text-ninetone-ink/60 md:col-span-5 md:pb-1 md:text-right">
          {releases.length} {releases.length === 1 ? "title" : "titles"} · newest first
        </p>
      </header>

      <ol class="flex flex-col gap-y-20 md:gap-y-28">
        {releases.map((r) => {
          const primaryHref = r.urlRelease || r.streaming.spotify || "#";
          const platforms = PLATFORMS.filter((p) => r.streaming[p.key]);
          return (
            <li class="group grid gap-8 md:grid-cols-12 md:gap-12">
              {/* Cover */}
              <a
                href={primaryHref}
                target="_blank"
                rel="noopener"
                aria-label={`Listen to ${r.album} by ${artistName}`}
                class="fm-img-frame relative block aspect-square overflow-hidden bg-ninetone-paper-warm md:col-span-5"
              >
                <img
                  src={r.cover}
                  alt={`${r.album} cover art`}
                  class="fm-img h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.03]"
                  loading="lazy"
                  onload="this.classList.add('is-loaded'); this.closest('.fm-img-frame')?.classList.add('is-ready')"
                />
                <span class={`absolute left-0 top-0 h-1 w-12 ${accent.bg} transition-[width] duration-500 ease-out group-hover:w-1/2`} aria-hidden></span>
              </a>

              {/* Copy + streaming */}
              <div class="flex flex-col gap-5 md:col-span-7 md:pt-2">
                <span class={`kicker ${accent.text}`}>
                  {r.type || "Release"}
                  <span class="mx-2 opacity-40" aria-hidden>·</span>
                  <time>{formatDate(r.releaseDate)}</time>
                </span>

                <h3 class="font-display text-3xl font-medium leading-[1.05] tracking-tight md:text-5xl">
                  {r.album}
                </h3>

                {r.pitch && (
                  <p class="max-w-2xl font-display text-xl italic leading-snug tracking-tight text-ninetone-ink/75 md:text-2xl">
                    {r.pitch}
                  </p>
                )}

                {r.urlRelease && (
                  <a
                    href={r.urlRelease}
                    target="_blank"
                    rel="noopener"
                    class={`mt-2 inline-flex items-center gap-2 self-start ${accent.cta} px-5 py-3 text-sm font-semibold transition-colors`}
                  >
                    Listen on your platform
                    <span aria-hidden>→</span>
                  </a>
                )}

                {platforms.length > 0 && (
                  <ul class="mt-1 flex flex-wrap gap-2">
                    {platforms.map((p) => (
                      <li>
                        <a
                          href={r.streaming[p.key]!}
                          target="_blank"
                          rel="noopener"
                          aria-label={`${r.album} on ${p.label}`}
                          title={p.label}
                          class="inline-flex h-9 min-w-9 items-center justify-center border border-ninetone-ink/15 px-2.5 text-[0.6875rem] font-semibold text-ninetone-ink/65 transition-colors hover:border-ninetone-ink hover:text-ninetone-ink"
                        >
                          {p.glyph || p.label.slice(0, 2)}
                        </a>
                      </li>
                    ))}
                  </ul>
                )}
              </div>
            </li>
          );
        })}
      </ol>
    </div>
  </section>
)}
