---
interface Metric {
  /** Big number — kept as string so we can use "120+" or "8.4M". */
  value: string;
  /** One-line label rendered under the value. */
  label: string;
  /** Optional small footnote rendered under the label. */
  note?: string;
}

interface Props {
  kicker?: string;
  heading?: string;
  metrics: Metric[];
  /** Visual variant. "ink" = dark band, "paper" = on canvas. */
  variant?: "ink" | "paper";
}

const {
  kicker = "By the numbers",
  heading = "Quietly moving Sweden — and beyond.",
  metrics,
  variant = "ink",
} = Astro.props as Props;

const wrapClass = variant === "ink" ? "bg-ninetone-ink text-ninetone-paper" : "bg-ninetone-paper text-ninetone-ink border-y border-ninetone-rule";
const subTextClass = variant === "ink" ? "text-ninetone-paper/60" : "text-ninetone-ink/55";
const ruleClass = variant === "ink" ? "bg-ninetone-paper/15" : "bg-ninetone-ink/15";
---

<section class={`${wrapClass}`}>
  <div class="mx-auto max-w-7xl px-6 py-20">
    <div class="grid gap-10 md:grid-cols-12 md:items-end">
      <div class="md:col-span-5">
        <span class={`kicker ${subTextClass}`}>{kicker}</span>
        <h2 class="mt-3 font-display text-4xl leading-[1.05] tracking-tight md:text-5xl">{heading}</h2>
      </div>
    </div>

    <dl class="mt-12 grid gap-x-8 gap-y-10 sm:grid-cols-2 lg:grid-cols-4">
      {metrics.map((m) => (
        <div class="flex flex-col gap-2">
          <span class={`block h-px w-12 ${ruleClass}`} aria-hidden></span>
          <dt class={`text-xs uppercase tracking-[0.16em] ${subTextClass}`}>{m.label}</dt>
          <dd class="font-display text-5xl font-medium leading-[0.95] tracking-[-0.03em] md:text-6xl">{m.value}</dd>
          {m.note && <span class={`text-xs ${subTextClass}`}>{m.note}</span>}
        </div>
      ))}
    </dl>
  </div>
</section>
