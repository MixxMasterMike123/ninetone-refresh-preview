---
import NewsCard from "./NewsCard.astro";
import { getNews } from "../lib/ninetone";
import { url } from "../lib/url";

interface Props {
  /** How many posts to show. Defaults to 2. */
  limit?: number;
  /** Heading shown above the cards. */
  heading?: string;
}

const { limit = 2, heading = "News" } = Astro.props as Props;

let posts: Awaited<ReturnType<typeof getNews>> = [];
try {
  posts = (await getNews()).slice(0, limit);
} catch {
  posts = [];
}

if (posts.length === 0) return Astro.redirect("");
---

<section class="bg-ninetone-paper-warm py-20">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mb-10 grid gap-4 md:grid-cols-[1fr_auto] md:items-end">
      <div>
        <span class="kicker text-ninetone-ink/55">Latest stories</span>
        <h2 class="mt-3 font-display text-4xl leading-[1.05] tracking-tight md:text-5xl">{heading}</h2>
      </div>
      <a href={url("/news")} class="inline-flex items-center gap-2 self-start text-xs font-semibold uppercase tracking-[0.16em] text-ninetone-ink">
        All news <span aria-hidden>→</span>
      </a>
    </div>
    <div class="grid gap-x-10 gap-y-12 md:grid-cols-2">
      {posts.map((p) => (
        <NewsCard
          title={String(p.Title ?? "")}
          slug={String(p.slug ?? "")}
          image={p.image_webp ? String(p.image_webp) : undefined}
          excerpt={String(p.shortMessage ?? p.Message ?? "")}
          date={String(p.Date ?? "")}
          author={String(p["Created By"] ?? "")}
          category={String(p.category ?? "")}
          size="lg"
        />
      ))}
    </div>
  </div>
</section>
