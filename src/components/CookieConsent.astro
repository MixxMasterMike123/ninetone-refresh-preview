---
// Ninetone cookie consent — hand-rolled, no paid service.
// Default-denied. Stores choice in localStorage key `ninetone_consent_v1`.
// Exposes window.ninetoneCookieConsent.{open, reset} so the footer link
// can reopen the banner. Wires Google Consent Mode v2, Meta Pixel
// (fbq consent), TikTok Pixel (ttq consent), Clarity gating on
// analytics consent.
---
<div id="cookie-consent" class="cookie-consent" hidden role="dialog" aria-labelledby="cookie-consent-title" aria-describedby="cookie-consent-desc">
  <div class="cookie-consent__inner">
    <div class="cookie-consent__copy">
      <span class="kicker text-ninetone-ink/55">Cookies</span>
      <p id="cookie-consent-desc" class="cookie-consent__text">
        <strong id="cookie-consent-title" class="cookie-consent__title">Vi använder cookies</strong>
        för att webbplatsen ska fungera, för att förstå hur besökare använder den och för att mäta marknadsföring.
        <a href="/integritet">Läs mer</a>.
      </p>
    </div>

    <div class="cookie-consent__actions" data-view="simple">
      <button type="button" class="cookie-consent__btn cookie-consent__btn--link" data-consent="customize">Anpassa</button>
      <button type="button" class="cookie-consent__btn cookie-consent__btn--secondary" data-consent="reject">Neka</button>
      <button type="button" class="cookie-consent__btn cookie-consent__btn--primary" data-consent="accept">Acceptera</button>
    </div>

    <div class="cookie-consent__options" data-view="customize" hidden>
      <fieldset class="cookie-consent__option">
        <label class="cookie-consent__option-label">
          <input type="checkbox" checked disabled />
          <span class="cookie-consent__option-title">Nödvändiga</span>
        </label>
        <p class="cookie-consent__option-text">Krävs för att webbplatsen ska fungera. Kan inte stängas av.</p>
      </fieldset>

      <fieldset class="cookie-consent__option">
        <label class="cookie-consent__option-label">
          <input type="checkbox" id="consent-analytics" />
          <span class="cookie-consent__option-title">Statistik och analys</span>
        </label>
        <p class="cookie-consent__option-text">Google Analytics och Microsoft Clarity hjälper oss förstå hur besökare använder webbplatsen.</p>
      </fieldset>

      <fieldset class="cookie-consent__option">
        <label class="cookie-consent__option-label">
          <input type="checkbox" id="consent-marketing" />
          <span class="cookie-consent__option-title">Marknadsföring</span>
        </label>
        <p class="cookie-consent__option-text">Meta Pixel och TikTok Pixel används för att mäta och rikta annonsering.</p>
      </fieldset>

      <div class="cookie-consent__actions cookie-consent__actions--customize">
        <button type="button" class="cookie-consent__btn cookie-consent__btn--secondary" data-consent="back">Tillbaka</button>
        <button type="button" class="cookie-consent__btn cookie-consent__btn--primary" data-consent="save">Spara val</button>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    var STORAGE_KEY = 'ninetone_consent_v1';
    var banner = document.getElementById('cookie-consent');
    if (!banner) return;

    var simpleView = banner.querySelector('[data-view="simple"]');
    var customizeView = banner.querySelector('[data-view="customize"]');
    var analyticsCheckbox = document.getElementById('consent-analytics');
    var marketingCheckbox = document.getElementById('consent-marketing');

    function loadConsent() {
      try {
        var raw = localStorage.getItem(STORAGE_KEY);
        return raw ? JSON.parse(raw) : null;
      } catch (e) {
        return null;
      }
    }

    function saveConsent(consent) {
      var record = {
        analytics: !!consent.analytics,
        marketing: !!consent.marketing,
        timestamp: new Date().toISOString(),
        version: 1
      };
      try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(record));
      } catch (e) {}
      applyConsent(record);
    }

    function applyConsent(consent) {
      // Google Consent Mode v2
      if (typeof window.gtag !== 'function') {
        window.dataLayer = window.dataLayer || [];
        window.gtag = function () { window.dataLayer.push(arguments); };
      }
      window.gtag('consent', 'update', {
        ad_storage: consent.marketing ? 'granted' : 'denied',
        ad_user_data: consent.marketing ? 'granted' : 'denied',
        ad_personalization: consent.marketing ? 'granted' : 'denied',
        analytics_storage: consent.analytics ? 'granted' : 'denied'
      });

      // Meta Pixel
      if (typeof window.fbq === 'function') {
        try {
          window.fbq('consent', consent.marketing ? 'grant' : 'revoke');
        } catch (e) {}
      }

      // TikTok Pixel
      if (typeof window.ttq !== 'undefined' && window.ttq && typeof window.ttq.load === 'function') {
        try {
          if (consent.marketing) {
            // ttq.load() is called when granted. If already loaded, this is idempotent.
            // The actual init happens via inline init script when consent is granted.
            window.dispatchEvent(new CustomEvent('ninetone:consent-marketing-granted'));
          }
        } catch (e) {}
      } else {
        // ttq not loaded yet — dispatch event for the init script to pick up
        window.dispatchEvent(new CustomEvent(
          consent.marketing ? 'ninetone:consent-marketing-granted' : 'ninetone:consent-marketing-revoked'
        ));
      }

      // Microsoft Clarity gates on analytics consent
      window.dispatchEvent(new CustomEvent(
        consent.analytics ? 'ninetone:consent-analytics-granted' : 'ninetone:consent-analytics-revoked'
      ));
    }

    var lastFocused = null;

    function getFocusable() {
      return Array.prototype.slice.call(
        banner.querySelectorAll('button:not([hidden]):not([disabled]), [href], input:not([disabled]):not([type="hidden"])')
      ).filter(function (el) {
        return el.offsetParent !== null;
      });
    }

    function showBanner() {
      lastFocused = document.activeElement;
      banner.hidden = false;
      simpleView.hidden = false;
      customizeView.hidden = true;
      var focusable = getFocusable();
      if (focusable.length) focusable[0].focus();
    }

    function hideBanner() {
      banner.hidden = true;
      if (lastFocused && typeof lastFocused.focus === 'function') {
        try { lastFocused.focus(); } catch (e) {}
      }
      lastFocused = null;
    }

    function showCustomize() {
      var existing = loadConsent();
      if (existing) {
        analyticsCheckbox.checked = existing.analytics;
        marketingCheckbox.checked = existing.marketing;
      }
      simpleView.hidden = true;
      customizeView.hidden = false;
      analyticsCheckbox.focus();
    }

    banner.addEventListener('keydown', function (event) {
      if (banner.hidden) return;

      if (event.key === 'Escape') {
        event.preventDefault();
        saveConsent({ analytics: false, marketing: false });
        hideBanner();
        return;
      }

      if (event.key === 'Tab') {
        var focusable = getFocusable();
        if (focusable.length === 0) return;
        var first = focusable[0];
        var last = focusable[focusable.length - 1];
        if (event.shiftKey && document.activeElement === first) {
          event.preventDefault();
          last.focus();
        } else if (!event.shiftKey && document.activeElement === last) {
          event.preventDefault();
          first.focus();
        }
      }
    });

    banner.addEventListener('click', function (event) {
      var target = event.target.closest('[data-consent]');
      if (!target) return;
      var action = target.getAttribute('data-consent');

      if (action === 'accept') {
        saveConsent({ analytics: true, marketing: true });
        hideBanner();
      } else if (action === 'reject') {
        saveConsent({ analytics: false, marketing: false });
        hideBanner();
      } else if (action === 'customize') {
        showCustomize();
      } else if (action === 'back') {
        simpleView.hidden = false;
        customizeView.hidden = true;
        var customizeBtn = banner.querySelector('[data-consent="customize"]');
        if (customizeBtn) customizeBtn.focus();
      } else if (action === 'save') {
        saveConsent({
          analytics: !!analyticsCheckbox.checked,
          marketing: !!marketingCheckbox.checked
        });
        hideBanner();
      }
    });

    // Public API — used by footer "Cookie-inställningar" link
    window.ninetoneCookieConsent = {
      open: showBanner,
      reset: function () {
        try { localStorage.removeItem(STORAGE_KEY); } catch (e) {}
        showBanner();
      },
      get: loadConsent
    };

    var stored = loadConsent();
    if (stored) {
      applyConsent(stored);
    } else {
      showBanner();
    }
  })();
</script>

<style>
  .cookie-consent {
    position: fixed;
    bottom: 1rem;
    left: 1rem;
    right: 1rem;
    max-width: 720px;
    margin: 0 auto;
    z-index: 70;
    background: var(--color-ninetone-paper);
    color: var(--color-ninetone-ink);
    border: 1px solid var(--color-ninetone-rule);
    box-shadow: 0 12px 40px -8px rgba(10, 20, 32, 0.18);
  }

  .cookie-consent[hidden] { display: none; }

  /* Accent rule top-left, Ninetone signature */
  .cookie-consent::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    height: 2px;
    width: 48px;
    background: var(--color-ninetone-ink);
  }

  .cookie-consent__inner {
    padding: 1.25rem 1.25rem;
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 1.5rem;
    align-items: flex-end;
    justify-content: space-between;
  }

  .cookie-consent__copy {
    flex: 1 1 280px;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .cookie-consent__title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.125rem;
    letter-spacing: -0.01em;
    color: var(--color-ninetone-ink);
    margin-right: 0.5rem;
  }

  .cookie-consent__text {
    font-size: 0.9375rem;
    line-height: 1.5;
    margin: 0;
    color: rgba(10, 20, 32, 0.78);
  }

  .cookie-consent__text a {
    color: var(--color-ninetone-ink);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .cookie-consent__text a:hover { color: var(--color-ninetone-red); }

  .cookie-consent__actions {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .cookie-consent__actions--customize {
    width: 100%;
    justify-content: flex-end;
    margin-top: 0.5rem;
  }

  .cookie-consent__btn {
    padding: 0.625rem 1rem;
    border: 1px solid transparent;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    cursor: pointer;
    transition: background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease;
    white-space: nowrap;
    min-height: 44px;
  }

  .cookie-consent__btn--primary {
    background: var(--color-ninetone-ink);
    color: var(--color-ninetone-paper);
  }

  .cookie-consent__btn--primary:hover {
    background: var(--color-ninetone-ink-soft);
  }

  .cookie-consent__btn--secondary {
    background: transparent;
    color: var(--color-ninetone-ink);
    border-color: var(--color-ninetone-ink);
  }

  .cookie-consent__btn--secondary:hover {
    background: var(--color-ninetone-ink);
    color: var(--color-ninetone-paper);
  }

  .cookie-consent__btn--link {
    background: transparent;
    border: none;
    color: rgba(10, 20, 32, 0.55);
    text-decoration: underline;
    text-underline-offset: 2px;
    padding: 0.625rem 0.5rem;
  }

  .cookie-consent__btn--link:hover { color: var(--color-ninetone-ink); }

  .cookie-consent__options {
    width: 100%;
    display: grid;
    gap: 0.75rem;
    padding-top: 1rem;
    margin-top: 0.5rem;
    border-top: 1px solid var(--color-ninetone-rule);
  }

  .cookie-consent__option {
    border: none;
    padding: 0;
    margin: 0;
  }

  .cookie-consent__option-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1rem;
    color: var(--color-ninetone-ink);
    cursor: pointer;
  }

  .cookie-consent__option-label input[disabled] { cursor: not-allowed; }

  .cookie-consent__option-text {
    margin: 0.25rem 0 0 1.625rem;
    font-size: 0.8125rem;
    color: rgba(10, 20, 32, 0.6);
    line-height: 1.45;
  }

  @media (max-width: 560px) {
    .cookie-consent {
      bottom: 0.5rem;
      left: 0.5rem;
      right: 0.5rem;
      max-height: calc(100vh - 1rem);
      overflow-y: auto;
    }

    .cookie-consent__inner {
      padding: 1rem;
      gap: 0.75rem;
    }

    .cookie-consent__text { font-size: 0.875rem; line-height: 1.45; }

    .cookie-consent__actions {
      width: 100%;
      justify-content: space-between;
      gap: 0.375rem;
    }

    .cookie-consent__btn { padding: 0.5rem 0.75rem; font-size: 0.625rem; }
    .cookie-consent__btn--primary,
    .cookie-consent__btn--secondary { flex: 1; }
    .cookie-consent__btn--link { flex: 0 0 auto; padding: 0.5rem 0.25rem; }

    .cookie-consent__options { gap: 0.5rem; padding-top: 0.75rem; }
    .cookie-consent__option-text { display: none; }
  }
</style>
