---
/**
 * YouTubeFeed — per-client recent uploads section on management/clients/[slug].
 *
 * Two filters:
 *   - Latest (RSS-driven, free)
 *   - Most viewed (Data API, optional — hides if API key missing or empty)
 *
 * Both lists are pre-fetched at build time (see src/lib/youtube.ts).
 * Filter state is purely client-side: tab buttons toggle data-active on the
 * container; CSS shows/hides the matching list. No JS framework needed.
 */
import type { YouTubeFeed } from "../lib/youtube";
import type { SectionTheme } from "../lib/sections";
import { sectionAccent } from "../lib/sections";

interface Props {
  feed: YouTubeFeed | null;
  clientName: string;
  theme?: SectionTheme;
}

const { feed, clientName, theme = "management" } = Astro.props;
const accent = sectionAccent[theme];

const latest = feed?.latest ?? [];
const topViewed = feed?.topViewed ?? [];
const hasTopViewed = topViewed.length > 0;
const total = latest.length;

function formatDate(iso: string): string {
  const d = new Date(iso);
  if (isNaN(d.getTime())) return "";
  const months = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
  return `${d.getDate()} ${months[d.getMonth()]} ${d.getFullYear()}`;
}

function formatViews(n: number | undefined): string {
  if (!n || n < 1) return "";
  if (n >= 1_000_000) return `${(n / 1_000_000).toFixed(1).replace(/\.0$/, "")}M views`;
  if (n >= 1_000) return `${Math.round(n / 1_000)}K views`;
  return `${n} views`;
}
---

{latest.length > 0 && (
  <section class="border-t border-ninetone-rule bg-ninetone-paper py-20 md:py-28">
    <div class="mx-auto max-w-7xl px-6">
      <header class="mb-8 grid gap-4 md:grid-cols-12 md:items-end">
        <div class="md:col-span-7">
          <span class={`kicker ${accent.text}`}>Management · YouTube</span>
          <h2 class="mt-3 font-display text-4xl leading-[1.05] tracking-tight md:text-6xl">
            Latest from the channel.
          </h2>
        </div>
        <p class="text-sm text-ninetone-ink/60 md:col-span-5 md:pb-1 md:text-right">
          {total} {total === 1 ? "video" : "videos"} · refreshes on each deploy
        </p>
      </header>

      <div
        id={`yt-feed-${clientName.replace(/\s+/g, "-").toLowerCase()}`}
        class="yt-feed"
        data-active="latest"
      >
        {/* Tabs */}
        <div class="mb-10 flex flex-wrap gap-2 border-b border-ninetone-rule pb-3">
          <button
            type="button"
            data-yt-tab="latest"
            class="kicker yt-tab px-3 py-2 text-ninetone-ink/55 transition-colors hover:text-ninetone-ink data-[active]:text-ninetone-ink"
            data-active
          >
            Latest
          </button>
          {hasTopViewed && (
            <button
              type="button"
              data-yt-tab="top"
              class="kicker yt-tab px-3 py-2 text-ninetone-ink/55 transition-colors hover:text-ninetone-ink data-[active]:text-ninetone-ink"
            >
              Most viewed
            </button>
          )}
        </div>

        {/* Latest list */}
        <ul
          class="yt-list grid grid-cols-2 gap-x-5 gap-y-10 md:grid-cols-3 lg:grid-cols-5"
          data-yt-list="latest"
        >
          {latest.map((v) => (
            <li>
              <a
                href={v.url}
                target="_blank"
                rel="noopener"
                class="group block"
                aria-label={`Watch ${v.title} on YouTube`}
              >
                <div class="fm-img-frame relative aspect-video w-full overflow-hidden bg-ninetone-paper-warm">
                  <img
                    src={v.thumbnail}
                    alt=""
                    class="fm-img h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.04]"
                    loading="lazy"
                    onload="this.classList.add('is-loaded'); this.closest('.fm-img-frame')?.classList.add('is-ready')"
                  />
                  <span class={`absolute left-0 top-0 h-1 w-10 ${accent.bg} transition-[width] duration-500 ease-out group-hover:w-full`} aria-hidden></span>
                </div>
                <p class="mt-3 line-clamp-2 font-display text-base font-medium leading-snug tracking-tight">
                  {v.title}
                </p>
                <p class="mt-1.5 text-[0.6875rem] uppercase tracking-[0.12em] text-ninetone-ink/55">
                  {formatDate(v.publishedAt)}
                </p>
              </a>
            </li>
          ))}
        </ul>

        {/* Most viewed list (only rendered when populated) */}
        {hasTopViewed && (
          <ul
            class="yt-list hidden grid-cols-2 gap-x-5 gap-y-10 md:grid-cols-3 lg:grid-cols-5"
            data-yt-list="top"
          >
            {topViewed.map((v) => (
              <li>
                <a
                  href={v.url}
                  target="_blank"
                  rel="noopener"
                  class="group block"
                  aria-label={`Watch ${v.title} on YouTube`}
                >
                  <div class="fm-img-frame relative aspect-video w-full overflow-hidden bg-ninetone-paper-warm">
                    <img
                      src={v.thumbnail}
                      alt=""
                      class="fm-img h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.04]"
                      loading="lazy"
                      onload="this.classList.add('is-loaded'); this.closest('.fm-img-frame')?.classList.add('is-ready')"
                    />
                    <span class={`absolute left-0 top-0 h-1 w-10 ${accent.bg} transition-[width] duration-500 ease-out group-hover:w-full`} aria-hidden></span>
                  </div>
                  <p class="mt-3 line-clamp-2 font-display text-base font-medium leading-snug tracking-tight">
                    {v.title}
                  </p>
                  <p class="mt-1.5 flex flex-wrap gap-x-2 text-[0.6875rem] uppercase tracking-[0.12em] text-ninetone-ink/55">
                    <span>{formatDate(v.publishedAt)}</span>
                    {v.views && (
                      <>
                        <span aria-hidden class="opacity-40">·</span>
                        <span>{formatViews(v.views)}</span>
                      </>
                    )}
                  </p>
                </a>
              </li>
            ))}
          </ul>
        )}
      </div>
    </div>

    <style>
      /* List visibility tied to container's data-active. CSS-only — tabs just
         flip the attribute on the container, no per-list state needed. */
      .yt-feed[data-active="latest"] [data-yt-list="top"] { display: none; }
      .yt-feed[data-active="top"] [data-yt-list="latest"] { display: none; }
      .yt-feed[data-active="top"] [data-yt-list="top"] { display: grid; }

      /* Active tab gets an underline mark + ink color. Tailwind's
         data-[active] modifier handles the color; we add the rule below. */
      .yt-tab { position: relative; }
      .yt-tab[data-active]::after {
        content: "";
        position: absolute;
        left: 0.75rem;
        right: 0.75rem;
        bottom: -0.85rem;
        height: 1px;
        background-color: currentColor;
      }
    </style>

    <script is:inline>
      // Defer until DOM is ready, then wire all yt-feed containers on the page.
      document.querySelectorAll(".yt-feed").forEach((root) => {
        const tabs = root.querySelectorAll("[data-yt-tab]");
        tabs.forEach((tab) => {
          tab.addEventListener("click", () => {
            const target = tab.getAttribute("data-yt-tab");
            if (!target) return;
            root.setAttribute("data-active", target);
            tabs.forEach((t) => {
              if (t === tab) t.setAttribute("data-active", "");
              else t.removeAttribute("data-active");
            });
          });
        });
      });
    </script>
  </section>
)}
