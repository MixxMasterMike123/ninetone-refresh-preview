---
import type { SectionTheme } from "../lib/sections";
import { sectionAccent, sectionCta } from "../lib/sections";
import { url } from "../lib/url";

interface Props {
  theme?: SectionTheme;
  lang?: "en" | "sv";
}

const { theme = "group", lang = "en" } = Astro.props;
const accent = sectionAccent[theme];
const cta = sectionCta[theme];
const ctaLabel = lang === "sv" ? cta.sv : cta.en;

const navItems = [
  { href: "/", labelEn: "Home", labelSv: "Hem", match: ["/"] },
  { href: "/records", labelEn: "Records", labelSv: "Records", match: ["/records"] },
  { href: "/management", labelEn: "Management", labelSv: "Management", match: ["/management"] },
  { href: "/ninetone-nation", labelEn: "Nation", labelSv: "Nation", match: ["/ninetone-nation"] },
  { href: "/news", labelEn: "News", labelSv: "Nyheter", match: ["/news"] },
  { href: "/team", labelEn: "Team", labelSv: "Team", match: ["/team"] },
];

const pathname = Astro.url.pathname;
const isActive = (matches: string[]) =>
  matches.some((m) => (m === "/" ? pathname === "/" : pathname === m || pathname.startsWith(`${m}/`)));
---

<header
  id="site-header"
  data-accent-hex={accent.hex}
  class="sticky top-0 z-40 border-b border-ninetone-rule bg-ninetone-paper/95 text-ninetone-ink backdrop-blur-md transition-[padding,background-color] duration-200"
>
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-6 px-6 py-4 transition-[padding] duration-200" id="site-header-inner">
    <a href={url("/")} class="flex shrink-0 items-center gap-3" aria-label="Ninetone Group">
      <img
        src={url("/images/LogoDark.svg")}
        alt="Ninetone Group"
        class="h-10 w-auto transition-[height] duration-200"
        id="site-header-logo"
      />
      <span class="hidden font-display text-lg font-medium tracking-tight md:inline">Ninetone Group</span>
    </a>

    <nav class="hidden flex-1 lg:block" aria-label="Primary">
      <ul class="flex items-center justify-center gap-1 text-[0.9375rem]">
        {navItems.map((item) => {
          const active = isActive(item.match);
          return (
            <li>
              <a
                href={url(item.href)}
                class={`relative inline-flex min-h-11 items-center px-3 py-2 font-medium transition-colors hover:text-ninetone-ink ${active ? accent.text : "text-ninetone-ink/65"}`}
                aria-current={active ? "page" : undefined}
              >
                {lang === "sv" ? item.labelSv : item.labelEn}
                {active && (
                  <span
                    class={`absolute inset-x-3 -bottom-0.5 h-px ${accent.bg}`}
                    aria-hidden
                  ></span>
                )}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>

    <div class="flex items-center gap-2">
      <button
        type="button"
        id="search-toggle"
        class="inline-flex h-11 items-center gap-2 rounded-none border border-ninetone-ink/15 px-3 text-sm text-ninetone-ink/70 transition-colors hover:border-ninetone-ink hover:text-ninetone-ink"
        aria-label={lang === "sv" ? "Sök" : "Search"}
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
          <circle cx="11" cy="11" r="7"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
        <span class="hidden text-xs font-medium tracking-wide md:inline">{lang === "sv" ? "Sök" : "Search"}</span>
        <kbd class="hidden rounded border border-ninetone-ink/15 px-1 py-px font-sans text-[0.625rem] font-medium text-ninetone-ink/50 md:inline">⌘K</kbd>
      </button>

      <a
        href={url(cta.href)}
        class={`hidden md:inline-flex min-h-11 items-center gap-2 px-4 py-2 text-sm font-semibold ${accent.cta} transition-colors`}
      >
        {ctaLabel}
        <span aria-hidden>→</span>
      </a>

      <a
        href={lang === "en" ? Astro.url.pathname.replace(/^\/en/, "/sv") : Astro.url.pathname.replace(/^\/sv/, "/en")}
        class="hidden md:inline-flex min-h-11 min-w-11 items-center justify-center px-2 text-xs font-semibold text-ninetone-ink/65 hover:text-ninetone-ink"
        aria-label={lang === "en" ? "Switch to Swedish" : "Switch to English"}
      >
        {lang === "en" ? "SV" : "EN"}
      </a>

      <button
        type="button"
        id="mobile-nav-toggle"
        class="inline-flex h-11 w-11 items-center justify-center border border-ninetone-ink/15 text-ninetone-ink transition-colors hover:border-ninetone-ink lg:hidden"
        aria-label={lang === "sv" ? "Öppna meny" : "Open menu"}
        aria-controls="mobile-nav-panel"
        aria-expanded="false"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" class="h-5 w-5" aria-hidden="true">
          <line x1="4" y1="7" x2="20" y2="7"></line>
          <line x1="4" y1="12" x2="20" y2="12"></line>
          <line x1="4" y1="17" x2="20" y2="17"></line>
        </svg>
      </button>
    </div>
  </div>
</header>

{/* Mobile nav panel — full-screen overlay, mounted as a header sibling so its
    z-index escapes the sticky <header>'s stacking context (z-40). */}
<div
  id="mobile-nav-panel"
  class="fixed inset-0 z-[60] hidden flex-col bg-ninetone-paper text-ninetone-ink lg:hidden"
  role="dialog"
  aria-modal="true"
  aria-label={lang === "sv" ? "Meny" : "Menu"}
>
  <div class="flex items-center justify-between border-b border-ninetone-rule px-6 py-4">
    <span class="kicker text-ninetone-ink/55">{lang === "sv" ? "Meny" : "Menu"}</span>
    <button
      type="button"
      id="mobile-nav-close"
      class="inline-flex h-11 w-11 items-center justify-center border border-ninetone-ink/15 text-ninetone-ink transition-colors hover:border-ninetone-ink"
      aria-label={lang === "sv" ? "Stäng meny" : "Close menu"}
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" class="h-5 w-5" aria-hidden="true">
        <line x1="6" y1="6" x2="18" y2="18"></line>
        <line x1="18" y1="6" x2="6" y2="18"></line>
      </svg>
    </button>
  </div>

  <nav class="flex-1 overflow-y-auto px-6 py-10" aria-label={lang === "sv" ? "Mobilnavigering" : "Mobile navigation"}>
    <ul class="flex flex-col gap-1">
      {navItems.map((item) => {
        const active = isActive(item.match);
        return (
          <li>
            <a
              href={url(item.href)}
              class={`group flex items-baseline justify-between gap-4 border-b border-ninetone-rule py-5 font-display text-3xl font-medium leading-tight tracking-tight transition-colors hover:text-ninetone-ink ${active ? accent.text : "text-ninetone-ink"}`}
              aria-current={active ? "page" : undefined}
            >
              <span>{lang === "sv" ? item.labelSv : item.labelEn}</span>
              <span class="text-base text-ninetone-ink/40 transition-transform duration-200 group-hover:translate-x-1" aria-hidden>→</span>
            </a>
          </li>
        );
      })}
    </ul>

    <div class="mt-10 flex flex-col gap-4">
      <a
        href={url(cta.href)}
        class={`inline-flex min-h-12 items-center justify-between gap-2 px-5 py-3 text-sm font-semibold ${accent.cta} transition-colors`}
      >
        {ctaLabel}
        <span aria-hidden>→</span>
      </a>
      <a
        href={lang === "en" ? Astro.url.pathname.replace(/^\/en/, "/sv") : Astro.url.pathname.replace(/^\/sv/, "/en")}
        class="kicker self-start text-ninetone-ink/55 hover:text-ninetone-ink"
      >
        {lang === "en" ? "Svenska →" : "English →"}
      </a>
    </div>
  </nav>
</div>

<script>
  // Search button → open command palette (managed by CommandPalette.astro,
  // which exposes window.ninetoneCmdK as a bridge).
  const toggle = document.getElementById("search-toggle");
  toggle?.addEventListener("click", () => {
    const open = (window as unknown as { ninetoneCmdK?: () => void }).ninetoneCmdK;
    open?.();
  });

  // Mobile nav: hamburger opens, X closes, ESC closes, click on any nav link
  // closes (so navigating to the same page doesn't leave the panel open).
  const navToggle = document.getElementById("mobile-nav-toggle");
  const navClose = document.getElementById("mobile-nav-close");
  const navPanel = document.getElementById("mobile-nav-panel");
  if (navToggle && navClose && navPanel) {
    const open = () => {
      navPanel.classList.remove("hidden");
      navPanel.classList.add("flex");
      navToggle.setAttribute("aria-expanded", "true");
      document.body.style.overflow = "hidden";
    };
    const close = () => {
      navPanel.classList.add("hidden");
      navPanel.classList.remove("flex");
      navToggle.setAttribute("aria-expanded", "false");
      document.body.style.overflow = "";
    };
    navToggle.addEventListener("click", open);
    navClose.addEventListener("click", close);
    navPanel.querySelectorAll("a").forEach((a) => a.addEventListener("click", close));
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !navPanel.classList.contains("hidden")) close();
    });
  }

  // Sticky scroll-shrink — logo and padding compress past 24px
  const header = document.getElementById("site-header");
  const inner = document.getElementById("site-header-inner");
  const logo = document.getElementById("site-header-logo");
  if (header && inner && logo) {
    let shrunk = false;
    const update = () => {
      const next = window.scrollY > 24;
      if (next === shrunk) return;
      shrunk = next;
      if (shrunk) {
        inner.classList.replace("py-4", "py-2");
        logo.classList.replace("h-10", "h-8");
      } else {
        inner.classList.replace("py-2", "py-4");
        logo.classList.replace("h-8", "h-10");
      }
    };
    update();
    window.addEventListener("scroll", update, { passive: true });
  }
</script>
