---
import type { SectionTheme } from "../lib/sections";
import { sectionAccent } from "../lib/sections";
import { url } from "../lib/url";

interface Props {
  theme?: SectionTheme;
  lang?: "en" | "sv";
}

const { theme = "group", lang = "en" } = Astro.props;
const accent = sectionAccent[theme];

const ctaCopy: Record<SectionTheme, { en: { title: string; body: string; cta: string; href: string }; sv: { title: string; body: string; cta: string; href: string } }> = {
  group: {
    en: { title: "We want your demos.", body: "Send us your music and we'll listen. We're always looking for the next voice.", cta: "Submit a demo", href: "/records/contact-records" },
    sv: { title: "Vi vill ha dina demos.", body: "Skicka in din musik så lyssnar vi. Vi söker alltid nästa röst.", cta: "Skicka demo", href: "/records/contact-records" },
  },
  records: {
    en: { title: "We want your demos.", body: "Send us your music and we'll listen. We're always looking for the next voice.", cta: "Submit a demo", href: "/records/contact-records" },
    sv: { title: "Vi vill ha dina demos.", body: "Skicka in din musik så lyssnar vi. Vi söker alltid nästa röst.", cta: "Skicka demo", href: "/records/contact-records" },
  },
  management: {
    en: { title: "We succeed together.", body: "Building a serious career in social and entertainment? Let's talk.", cta: "Get in touch", href: "/management/contact-management" },
    sv: { title: "Vi lyckas tillsammans.", body: "Bygger du en seriös karriär inom social och underhållning? Hör av dig.", cta: "Kontakta oss", href: "/management/contact-management" },
  },
  nation: {
    en: { title: "Book your next moment.", body: "Sweden's leading artists and entertainers, available for your event.", cta: "Booking request", href: "/ninetone-nation/contact-ninetone-nation" },
    sv: { title: "Boka ditt nästa ögonblick.", body: "Sveriges främsta artister och underhållare, redo för ditt event.", cta: "Bokningsförfrågan", href: "/ninetone-nation/contact-ninetone-nation" },
  },
};

const copy = ctaCopy[theme][lang];

const exploreLinks = [
  { href: "/records", labelEn: "Records", labelSv: "Records" },
  { href: "/management", labelEn: "Management", labelSv: "Management" },
  { href: "/ninetone-nation", labelEn: "Nation", labelSv: "Nation" },
  { href: "/news", labelEn: "News", labelSv: "Nyheter" },
  { href: "/team", labelEn: "Team", labelSv: "Team" },
  { href: "/records/artists/previous", labelEn: "Previous artists", labelSv: "Tidigare artister" },
];

const studioLinks = [
  { href: "/records/contact-records", labelEn: "Submit a demo", labelSv: "Skicka demo" },
  { href: "/management/contact-management", labelEn: "Management enquiry", labelSv: "Förfrågan management" },
  { href: "/ninetone-nation/booking", labelEn: "Book talent", labelSv: "Boka talang" },
  { href: "/ninetone-nation/contact-ninetone-nation", labelEn: "Press", labelSv: "Press" },
];

const socials = [
  { name: "Instagram", href: "https://www.instagram.com/ninetonemanagement/" },
  { name: "TikTok", href: "https://www.tiktok.com/@ninetone.com?lang=en" },
  { name: "YouTube", href: "https://www.youtube.com/c/Ninetone" },
  { name: "Spotify", href: "https://open.spotify.com/user/ninetone2?si=c124f60ffa214a47" },
  { name: "Apple Music", href: "https://music.apple.com/us/playlist/nmf-ninetone/pl.u-d2b05dYsLeMR9AZ" },
  { name: "SoundCloud", href: "https://soundcloud.com/ninetonegroup" },
  { name: "Facebook", href: "https://www.facebook.com/ninetone/" },
  { name: "Threads", href: "https://www.threads.net/@ninetonegroup" },
  { name: "X / Twitter", href: "https://twitter.com/ninetonegroup" },
  { name: "LinkedIn", href: "https://www.linkedin.com/company/ninetone" },
  { name: "Vimeo", href: "https://vimeo.com/user188122269" },
  { name: "Wikipedia", href: "https://sv.wikipedia.org/wiki/Ninetone_Records" },
];
---

<footer class="bg-ninetone-ink text-ninetone-paper">
  <!-- Demo / talent / booking pitch panel -->
  <section class="border-b border-white/10">
    <div class="mx-auto grid max-w-7xl gap-10 px-6 py-16 md:grid-cols-[1.1fr_0.9fr] md:gap-16 md:py-24">
      <div>
        <span class="kicker text-ninetone-paper/60">{lang === "sv" ? "Berätta för oss" : "Talk to us"}</span>
        <h2 class="mt-4 font-display text-4xl leading-[1.05] tracking-tight md:text-6xl">
          {copy.title}
        </h2>
        <p class="mt-5 max-w-xl text-base text-ninetone-paper/75 md:text-lg">{copy.body}</p>
        <a
          href={url(copy.href)}
          class={`mt-8 inline-flex items-center gap-3 px-5 py-3 text-sm font-semibold ${accent.cta}`}
        >
          {copy.cta} <span aria-hidden>→</span>
        </a>
      </div>

      <!-- Newsletter capture -->
      <div class="md:pl-10 md:border-l md:border-white/10">
        <span class="kicker text-ninetone-paper/60">{lang === "sv" ? "Nyhetsbrev" : "Newsletter"}</span>
        <h3 class="mt-4 font-display text-2xl leading-tight tracking-tight md:text-3xl">
          {lang === "sv" ? "Signaler från Ninetone." : "Signals from Ninetone."}
        </h3>
        <p class="mt-3 max-w-md text-sm leading-relaxed text-ninetone-paper/70">
          Releaser, projekt, case, möjligheter och berättelser från platsen där kultur, publik och affär möts.
        </p>
        <form
          method="post"
          action={url("/api/subscribe")}
          class="mt-6 flex flex-col gap-2 sm:flex-row sm:items-stretch"
          data-newsletter
        >
          <label class="sr-only" for="newsletter-email">{lang === "sv" ? "E-post" : "Email"}</label>
          <input
            id="newsletter-email"
            type="email"
            name="email"
            required
            placeholder={lang === "sv" ? "namn@email.com" : "you@email.com"}
            class="w-full border border-white/20 bg-transparent px-4 py-3 text-sm text-ninetone-paper placeholder-ninetone-paper/40 focus:border-white focus:outline-none"
          />
          <button
            type="submit"
            class="shrink-0 bg-ninetone-paper px-5 py-3 text-sm font-semibold text-ninetone-ink transition-colors hover:bg-white"
          >
            {lang === "sv" ? "Prenumerera" : "Subscribe"}
          </button>
        </form>
        <p class="mt-3 text-xs text-ninetone-paper/45">
          {lang === "sv" ? "Inga spam. Avregistrera när du vill." : "No spam. Unsubscribe any time."}
        </p>
      </div>
    </div>
  </section>

  <!-- Link columns -->
  <section class="border-b border-white/10">
    <div class="mx-auto grid max-w-7xl grid-cols-2 gap-x-6 gap-y-10 px-6 py-12 md:grid-cols-[1.4fr_1fr_1fr_1fr] md:gap-10">
      <div class="col-span-2 flex flex-col gap-4 md:col-span-1">
        <a href={url("/")} class="inline-flex items-center gap-3" aria-label="Ninetone Group">
          <img src={url("/images/ninetoneSQlogo.png")} alt="" class="h-12 w-auto" />
          <span class="font-display text-xl font-medium tracking-tight">Ninetone</span>
        </a>
        <p class="max-w-xs text-sm text-ninetone-paper/60">
          {lang === "sv"
            ? "Ett hus för musik, talang, varumärken, offentliga personer och publiken de behöver nå. Sundsvall / Stockholm, Sverige."
            : "A house for music, talent, brands, public people and the audiences they need to reach. Sundsvall / Stockholm, Sweden."}
        </p>
      </div>

      <div>
        <span class="kicker text-ninetone-paper/45">{lang === "sv" ? "Utforska" : "Explore"}</span>
        <ul class="mt-4 space-y-2.5 text-sm">
          {exploreLinks.map((item) => (
            <li>
              <a href={url(item.href)} class="text-ninetone-paper/85 transition-colors hover:text-ninetone-paper">
                {lang === "sv" ? item.labelSv : item.labelEn}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <span class="kicker text-ninetone-paper/45">{lang === "sv" ? "Studio" : "Studio"}</span>
        <ul class="mt-4 space-y-2.5 text-sm">
          {studioLinks.map((item) => (
            <li>
              <a href={url(item.href)} class="text-ninetone-paper/85 transition-colors hover:text-ninetone-paper">
                {lang === "sv" ? item.labelSv : item.labelEn}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="col-span-2 md:col-span-1">
        <span class="kicker text-ninetone-paper/45">{lang === "sv" ? "Följ" : "Follow"}</span>
        <ul class="mt-4 grid grid-cols-2 gap-x-4 gap-y-2.5 text-sm">
          {socials.map((s) => (
            <li>
              <a
                href={s.href}
                target="_blank"
                rel="noopener"
                class="inline-flex items-center gap-1.5 text-ninetone-paper/85 transition-colors hover:text-ninetone-paper"
                aria-label={s.name}
              >
                {s.name} <span aria-hidden class="text-[0.625rem] opacity-50">↗</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <div class="mx-auto flex max-w-7xl flex-col items-start justify-between gap-3 px-6 py-6 text-xs text-ninetone-paper/50 sm:flex-row sm:items-center">
    <p>© Ninetone Group {new Date().getFullYear()}. {lang === "sv" ? "Alla rättigheter förbehålls." : "All rights reserved."}</p>
    <p class="font-display italic tracking-tight">{lang === "sv" ? "Sundsvall — gjord med omsorg." : "Sundsvall — made with care."}</p>
  </div>
</footer>

<script>
  // Newsletter subscribe — POSTs to /api/subscribe and surfaces the result.
  document.querySelectorAll<HTMLFormElement>("form[data-newsletter]").forEach((form) => {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const input = form.elements.namedItem("email") as HTMLInputElement | null;
      const email = input?.value?.trim();
      const button = form.querySelector("button[type=submit]") as HTMLButtonElement | null;
      if (!email || !button) return;

      const original = button.textContent;
      button.textContent = "Subscribing…";
      button.disabled = true;
      try {
        const base = import.meta.env.BASE_URL.replace(/\/$/, "");
        const res = await fetch(`${base}/api/subscribe`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ email }),
        });
        if (res.ok) {
          button.textContent = "Thanks ✓";
          input!.value = "";
        } else {
          button.textContent = "Try again";
          button.disabled = false;
          setTimeout(() => { if (button.textContent === "Try again") button.textContent = original; }, 2500);
        }
      } catch {
        button.textContent = "Try again";
        button.disabled = false;
        setTimeout(() => { if (button.textContent === "Try again") button.textContent = original; }, 2500);
      }
    });
  });
</script>
