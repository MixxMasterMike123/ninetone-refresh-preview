---
import { url } from "../lib/url";

interface Props {
  active: "current" | "previous";
}

const { active } = Astro.props as Props;

const tabs: { key: "current" | "previous"; label: string; href: string }[] = [
  { key: "current", label: "Artists", href: "/records/artists" },
  { key: "previous", label: "Previous Artists", href: "/records/artists/previous" },
];
---

<div class="mb-12 flex items-center gap-6 border-b border-ninetone-rule pb-3">
  {tabs.map((t) => {
    const isActive = t.key === active;
    return (
      <a
        href={url(t.href)}
        class={
          isActive
            ? "relative -mb-3 border-b-2 border-ninetone-red pb-3 text-sm font-semibold text-ninetone-ink"
            : "relative -mb-3 border-b-2 border-transparent pb-3 text-sm font-medium text-ninetone-ink/55 hover:text-ninetone-ink"
        }
        aria-current={isActive ? "page" : undefined}
      >
        {t.label}
      </a>
    );
  })}
</div>
