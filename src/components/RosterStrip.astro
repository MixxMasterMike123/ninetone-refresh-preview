---
import type { Artist } from "../lib/ninetone";
import type { SectionTheme } from "../lib/sections";
import { sectionAccent } from "../lib/sections";
import { url } from "../lib/url";

interface Props {
  artists: Artist[];
  theme?: SectionTheme;
  hrefBase?: string;
  kicker?: string;
  heading?: string;
  cta?: { label: string; href: string };
}

const {
  artists,
  theme = "records",
  hrefBase = "/records/artists",
  kicker = "The roster",
  heading = "Artists in residence.",
  cta = { label: "View all", href: "/records/artists" },
} = Astro.props as Props;

const accent = sectionAccent[theme];
---

<section class="bg-ninetone-paper py-20">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mb-10 grid gap-4 md:grid-cols-[1fr_auto] md:items-end">
      <div>
        <span class={`kicker ${accent.text}`}>{kicker}</span>
        <h2 class="mt-3 font-display text-4xl leading-[1.05] tracking-tight md:text-5xl">{heading}</h2>
      </div>
      <a href={url(cta.href)} class="inline-flex items-center gap-2 self-start text-xs font-semibold uppercase tracking-[0.16em] text-ninetone-ink">
        {cta.label} <span aria-hidden>→</span>
      </a>
    </div>
  </div>

  <div class="mx-auto max-w-7xl">
    <ul
      class="flex snap-x snap-mandatory gap-3 overflow-x-auto px-6 pb-6 pr-12 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
      data-roster-strip
    >
      {artists.map((a) => {
        const name = String(a["Head Artist"] ?? "");
        const slug = String(a.SLUG ?? "");
        const img = a.artistPicture_small ? String(a.artistPicture_small) : undefined;
        const href = url(`${hrefBase}/${slug}`);
        return (
          <li class="snap-start shrink-0">
            <a href={href} class="group block w-[180px] md:w-[220px] lg:w-[240px]">
              <div class="relative aspect-[3/4] w-full overflow-hidden bg-ninetone-paper-warm">
                {img && (
                  <img
                    src={img}
                    alt={name}
                    class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.05]"
                    loading="lazy"
                  />
                )}
                <span class={`absolute left-0 top-0 h-1 w-10 ${accent.bg} transition-[width] duration-300 ease-out group-hover:w-full`} aria-hidden></span>
              </div>
              <p class="mt-3 font-display text-base font-medium leading-tight tracking-tight">{name}</p>
            </a>
          </li>
        );
      })}
    </ul>
  </div>
</section>
