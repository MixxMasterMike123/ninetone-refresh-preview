---
import { renderBio } from "../lib/markdown";
import type { WebPostCategory } from "../lib/ninetone";

interface Props {
  data: WebPostCategory | null;
  /** Optional: override the page heading. Default uses data.title. */
  heading?: string;
}

const { data, heading } = Astro.props as Props;

if (!data || data.blocks.length === 0) return Astro.redirect("");

// Subjects sometimes arrive HTML-wrapped (e.g. "<h2>Foo</h2>"); strip any
// outer tag so we can render them as a consistent <h2> ourselves.
function stripOuterTag(s: string): string {
  return s.replace(/^\s*<([a-z0-9]+)[^>]*>([\s\S]*?)<\/\1>\s*$/i, "$2").trim();
}

const blocks = data.blocks.map((b) => ({
  subject: stripOuterTag(b.subject),
  messageHtml: renderBio(b.message),
}));

const pageTitle = heading ?? data.title;
---

<section class="bg-ninetone-paper py-20">
  <div class="mx-auto grid max-w-7xl gap-10 px-6 md:grid-cols-12 md:gap-16">
    <div class="md:col-span-4 md:sticky md:top-28 md:self-start">
      {pageTitle && (
        <>
          <span class="kicker text-ninetone-ink/55">About</span>
          <h2 class="mt-3 font-display text-4xl leading-[1.05] tracking-tight md:text-5xl">{pageTitle}</h2>
        </>
      )}
    </div>
    <div class="md:col-span-8 space-y-12">
      {blocks.map((b) => (
        <div>
          {b.subject && (
            <h3 class="font-display text-2xl leading-tight tracking-tight md:text-3xl">{b.subject}</h3>
          )}
          <div class="prose mt-4 max-w-2xl" set:html={b.messageHtml}></div>
        </div>
      ))}
    </div>
  </div>
</section>
