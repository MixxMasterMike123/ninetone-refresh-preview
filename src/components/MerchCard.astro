---
import type { ShopifyProduct } from "../lib/shopify";
import { productUrl, productPrice } from "../lib/shopify";

interface Props {
  product: ShopifyProduct;
  lang?: "en" | "sv";
}

const { product, lang = "en" } = Astro.props as Props;
const cta = lang === "sv" ? "Till butiken" : "To the Shop";
const img = product.image ?? product.images[0] ?? null;
---

<article class="flex flex-col overflow-hidden rounded-sm bg-ninetone-card text-white">
  <a href={productUrl(product)} target="_blank" rel="noopener" class="block aspect-square overflow-hidden bg-neutral-200">
    {img && <img src={img.src} alt={img.alt ?? product.title} class="h-full w-full object-cover" loading="lazy" />}
  </a>
  <div class="flex flex-1 flex-col gap-2 p-4">
    <h3 class="text-base font-semibold leading-tight">{product.title}</h3>
    <p class="text-sm opacity-80">{productPrice(product)}</p>
    <a href={productUrl(product)} target="_blank" rel="noopener" class="mt-auto inline-flex items-center gap-2 self-start rounded-sm bg-ninetone-green px-3 py-1.5 text-xs font-semibold hover:bg-ninetone-green-dark">
      {cta} <span aria-hidden>→</span>
    </a>
  </div>
</article>
