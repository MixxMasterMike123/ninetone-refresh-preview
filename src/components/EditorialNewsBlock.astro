---
import NewsCard from "./NewsCard.astro";
import { getNews } from "../lib/ninetone";

interface Props {
  /** Total stories to render. The first becomes the lead, the rest are grid items. */
  limit?: number;
  /** Section heading. */
  heading?: string;
  /** Kicker label rendered above the heading. */
  kicker?: string;
  /** "All news" CTA destination. */
  href?: string;
  /** Visual canvas. "paper" matches the page; "warm" is the off-cream variant. */
  variant?: "paper" | "warm";
}

const {
  limit = 5,
  heading = "Latest stories.",
  kicker = "From the studios",
  href = "/news",
  variant = "warm",
} = Astro.props as Props;

let posts: Awaited<ReturnType<typeof getNews>> = [];
try {
  posts = (await getNews()).slice(0, limit);
} catch {
  posts = [];
}

if (posts.length === 0) return Astro.redirect("");
const [lead, ...rest] = posts;

const bg = variant === "warm" ? "bg-ninetone-paper-warm" : "bg-ninetone-paper";
---

<section class={`${bg} py-20`}>
  <div class="mx-auto max-w-7xl px-6">
    <div class="mb-12 grid gap-4 md:grid-cols-[1fr_auto] md:items-end">
      <div>
        <span class="kicker text-ninetone-ink/55">{kicker}</span>
        <h2 class="mt-3 font-display text-4xl leading-[1.05] tracking-tight md:text-5xl">{heading}</h2>
      </div>
      <a href={href} class="inline-flex items-center gap-2 self-start text-xs font-semibold uppercase tracking-[0.16em] text-ninetone-ink">
        All news <span aria-hidden>→</span>
      </a>
    </div>

    <div class="grid gap-x-12 gap-y-12 md:grid-cols-12">
      {lead && (
        <div class="md:col-span-7">
          <NewsCard
            title={String(lead.Title ?? "")}
            slug={String(lead.slug ?? "")}
            image={lead.image_webp ? String(lead.image_webp) : undefined}
            excerpt={String(lead.shortMessage ?? lead.Message ?? "")}
            date={String(lead.Date ?? "")}
            author={String(lead["Created By"] ?? "")}
            category={String(lead.category ?? "")}
            size="lg"
          />
        </div>
      )}
      {rest.length > 0 && (
        <ul class="md:col-span-5 space-y-8">
          {rest.map((p) => (
            <li class="border-t border-ninetone-rule pt-6 first:border-0 first:pt-0">
              <NewsCard
                title={String(p.Title ?? "")}
                slug={String(p.slug ?? "")}
                image={p.image_webp ? String(p.image_webp) : undefined}
                excerpt={String(p.shortMessage ?? p.Message ?? "")}
                date={String(p.Date ?? "")}
                category={String(p.category ?? "")}
                size="sm"
              />
            </li>
          ))}
        </ul>
      )}
    </div>
  </div>
</section>
