# FileMaker Data API (build-time only — never expose to client)
FM_HOST=files.ninetone.com
FM_DB=Ninetone Group AB
FM_USER=
FM_PASS=

# Shopify Admin API (build-time only — token has full store r/w access).
# SHOPIFY_SHOP_DOMAIN is the *.myshopify.com host, not the public storefront URL.
# Roadmap: swap to Storefront API before launch (see docs/api-shopify.md).
SHOPIFY_SHOP_DOMAIN=fc6d3a-d9.myshopify.com
SHOPIFY_PUBLIC_STORE_URL=https://shop.ninetone.com
SHOPIFY_ADMIN_TOKEN=
SHOPIFY_HOMEPAGE_COLLECTION_ID=514085060873

# Cloudflare deploy hook (set FileMaker "Publish" script to POST here)
CF_DEPLOY_HOOK=

# YouTube Data API v3 key. Used at build time to fetch top-viewed videos
# per Management client. Free tier: 10k quota units/day. Without this,
# YouTubeFeed component falls back to RSS-only (Latest tab) and hides the
# Most viewed tab. Get one from console.cloud.google.com → APIs → YouTube
# Data API v3 → Credentials. Restrict to "YouTube Data API v3" only.
YOUTUBE_API_KEY=

# Set to "false" on the public production launch. While true (default), every
# page renders <meta name="robots" content="noindex,..."> AND the X-Robots-Tag
# header in public/_headers + the sitewide disallow in public/robots.txt apply.
# This is the kill switch — all three layers stay until launch day.
PUBLIC_NOINDEX=true
